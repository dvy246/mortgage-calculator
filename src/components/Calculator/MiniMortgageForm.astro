---
interface Props {
  defaultHomePrice?: number;
  defaultDownPayment?: number;
  defaultRate?: number;
  defaultTerm?: number;
  defaultTaxRate?: number;
  defaultInsuranceRate?: number;
  scenarioPrefix?: string;
}
const {
  defaultHomePrice = 400000,
  defaultDownPayment = 80000,
  defaultRate = 6.5,
  defaultTerm = 30,
  defaultTaxRate = 1.1,
  defaultInsuranceRate = 0.5,
  scenarioPrefix = 'Custom'
} = Astro.props;
---

<div class="rounded-xl border border-border-subtle bg-bg-card p-4 sm:p-5 space-y-4" id="mini-mortgage-form" data-prefix={scenarioPrefix}>
  <h4 class="font-display text-xs font-semibold text-text-main">Add Custom Scenario</h4>
  <p class="text-3xs text-text-muted -mt-2">Adjust any variable and click "Add to Comparison" to create a new scenario.</p>

  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-xs">
    <div class="space-y-1">
      <label for="mini-price" class="font-medium text-text-muted text-3xs">Home Price</label>
      <input type="number" id="mini-price" value={defaultHomePrice} class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none" />
    </div>
    <div class="space-y-1">
      <label for="mini-down" class="font-medium text-text-muted text-3xs">Down Payment</label>
      <input type="number" id="mini-down" value={defaultDownPayment} class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none" />
    </div>
    <div class="space-y-1">
      <label for="mini-rate" class="font-medium text-text-muted text-3xs">Interest Rate %</label>
      <input type="number" id="mini-rate" value={defaultRate} step="0.1" class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none" />
    </div>
    <div class="space-y-1">
      <label for="mini-term" class="font-medium text-text-muted text-3xs">Term</label>
      <select id="mini-term" class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main focus:border-border-focus focus:outline-none">
        <option value="30" selected={defaultTerm === 30}>30 Years</option>
        <option value="20" selected={defaultTerm === 20}>20 Years</option>
        <option value="15" selected={defaultTerm === 15}>15 Years</option>
        <option value="10" selected={defaultTerm === 10}>10 Years</option>
      </select>
    </div>
    <div class="space-y-1">
      <label for="mini-tax" class="font-medium text-text-muted text-3xs">Tax Rate %</label>
      <input type="number" id="mini-tax" value={defaultTaxRate} step="0.1" class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none" />
    </div>
    <div class="space-y-1">
      <label for="mini-ins" class="font-medium text-text-muted text-3xs">Insurance Rate %</label>
      <input type="number" id="mini-ins" value={defaultInsuranceRate} step="0.1" class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none" />
    </div>
  </div>

  <button
    id="mini-add-scenario-btn"
    class="inline-flex h-8 items-center justify-center rounded-md bg-blue-600 px-4 text-xs font-semibold text-white hover:bg-blue-500 active:scale-[0.98] transition-all cursor-pointer gap-1.5"
  >
    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
    Add to Comparison
  </button>
</div>

<script>
  import { calculateMortgage } from '../../utils/mortgage';

  const form = document.getElementById('mini-mortgage-form');
  const prefix = form?.getAttribute('data-prefix') || 'Custom';

  const priceInput = document.getElementById('mini-price') as HTMLInputElement;
  const downInput = document.getElementById('mini-down') as HTMLInputElement;
  const rateInput = document.getElementById('mini-rate') as HTMLInputElement;
  const termSelect = document.getElementById('mini-term') as HTMLSelectElement;
  const taxInput = document.getElementById('mini-tax') as HTMLInputElement;
  const insInput = document.getElementById('mini-ins') as HTMLInputElement;
  const addBtn = document.getElementById('mini-add-scenario-btn');

  if (addBtn) {
    addBtn.addEventListener('click', () => {
      const homePrice = parseFloat(priceInput?.value) || 400000;
      const downPayment = parseFloat(downInput?.value) || 80000;
      const interestRate = parseFloat(rateInput?.value) || 6.5;
      const loanTermYears = parseInt(termSelect?.value) || 30;
      const propertyTaxRate = parseFloat(taxInput?.value) || 1.1;
      const insuranceRate = parseFloat(insInput?.value) || 0.5;

      const result = calculateMortgage({
        homePrice,
        downPayment,
        interestRate,
        loanTermYears,
        propertyTaxRate,
        insuranceRate,
        pmiRate: 0.75,
        hoaFee: 0,
        extraMonthly: 0,
        extraAnnual: 0,
        extraOneTime: []
      });

      if ((window as any).autoCaptureScenario) {
        (window as any).autoCaptureScenario(
          'mortgage',
          {
            homePrice,
            downPayment,
            interestRate,
            loanTermYears,
            propertyTaxRate,
            insuranceRate,
            pmiRate: 0.75,
            hoaFee: 0,
            extraMonthly: 0,
            extraAnnual: 0
          },
          {
            monthlyPayment: result.totalMonthlyPayment,
            totalInterest: result.totalInterestPaid,
            totalCost: result.totalPaymentsSum,
            payoffYears: result.payoffTermMonths / 12,
            homePrice,
            downPayment,
            interestRate,
            termYears: loanTermYears,
            monthlyPI: result.monthlyPrincipalAndInterest,
            monthlyTax: result.monthlyPropertyTax,
            monthlyInsurance: result.monthlyInsurance,
            monthlyPMI: result.monthlyPMI,
            monthlyHOA: result.monthlyHOA,
            pmiCancellationMonth: result.pmiCancellationMonth > 0 ? result.pmiCancellationMonth : undefined
          }
        );
      }
    });
  }
</script>
