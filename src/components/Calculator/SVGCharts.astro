  // 1. Donut Renderer
  function renderDonutSVG(pi: number, tax: number, ins: number, pmi: number, hoa: number) {
    const total = pi + tax + ins + pmi + hoa;
    const donutTotalEl = document.getElementById('donut-total');
    if (donutTotalEl) donutTotalEl.textContent = `$${Math.round(total).toLocaleString('en-US')}`;

    const setLegend = (id: string, val: number) => {
      const el = document.getElementById(id);
      if (el) el.textContent = `$${Math.round(val).toLocaleString('en-US')}`;
    };
    setLegend('legend-pi-val', pi);
    setLegend('legend-tax-val', tax);
    setLegend('legend-ins-val', ins);

    const pmiRow = document.getElementById('legend-pmi-row');
    if (pmiRow) {
      if (pmi > 0) {
        pmiRow.style.display = 'flex';
        setLegend('legend-pmi-val', pmi);
      } else {
        pmiRow.style.display = 'none';
      }
    }

    const hoaRow = document.getElementById('legend-hoa-row');
    if (hoaRow) {
      if (hoa > 0) {
        hoaRow.style.display = 'flex';
        setLegend('legend-hoa-val', hoa);
      } else {
        hoaRow.style.display = 'none';
      }
    }

    const circ = 251.2;
    const segments = [
      { id: 'donut-segment-pi', val: pi },
      { id: 'donut-segment-tax', val: tax },
      { id: 'donut-segment-ins', val: ins },
      { id: 'donut-segment-pmi', val: pmi },
      { id: 'donut-segment-hoa', val: hoa }
    ];

    let currentOffset = 0;
    segments.forEach(seg => {
      const el = document.getElementById(seg.id);
      if (el) {
        if (total === 0) {
          el.setAttribute('stroke-dashoffset', String(circ));
        } else {
          const ratio = seg.val / total;
          const strokeLength = ratio * circ;
          el.setAttribute('stroke-dasharray', `${strokeLength} ${circ}`);
          el.setAttribute('stroke-dashoffset', String(-currentOffset));
          currentOffset += strokeLength;
        }
      }
    });

    updateLiveRegion(`Monthly cost breakdown donut chart. Total estimated monthly payment is $${Math.round(total).toLocaleString('en-US')}. Principal and interest is $${Math.round(pi).toLocaleString('en-US')}, property taxes is $${Math.round(tax).toLocaleString('en-US')}, insurance is $${Math.round(ins).toLocaleString('en-US')}, PMI is $${Math.round(pmi).toLocaleString('en-US')}, HOA is $${Math.round(hoa).toLocaleString('en-US')}.`);
  }

  // 2. Area Renderer
  function renderAreaSVG() {
    if (globalSchedule.length === 0) return;
    const svg = document.getElementById('area-svg');
    if (!svg) return;

    const width = 400;
    const totalMonths = globalSchedule.length;
    const totalYears = Math.ceil(totalMonths / 12);
    
    // Draw vertical grids and labels
    drawGridAndLabels('area', totalYears);

    const lastEntry = globalSchedule[totalMonths - 1];
    
    // Scale max value according to baseline if visible
    const showBase = compareCheckbox?.checked && globalBaselineSchedule.length > 0;
    const lastBaseEntry = showBase ? globalBaselineSchedule[globalBaselineSchedule.length - 1] : null;
    const maxVal = Math.max(
      lastEntry.cumulativePrincipal + lastEntry.cumulativeInterest,
      lastBaseEntry ? lastBaseEntry.cumulativePrincipal + lastBaseEntry.cumulativeInterest : 0
    );

    let prinPoints = "";
    let intPoints = "";
    const step = Math.max(1, Math.floor(totalMonths / 60));
    
    // 175 is the axis baseline, 10 is top offset, total usable height is 165
    for (let i = 0; i < totalMonths; i += step) {
      const entry = globalSchedule[i];
      const x = (i / (totalMonths - 1)) * width;
      const yPrin = 175 - (entry.cumulativePrincipal / maxVal) * 165;
      const yInt = 175 - ((entry.cumulativePrincipal + entry.cumulativeInterest) / maxVal) * 165;

      const prefix = i === 0 ? "M" : "L";
      prinPoints += `${prefix} ${x.toFixed(1)} ${yPrin.toFixed(1)} `;
      intPoints += `${prefix} ${x.toFixed(1)} ${yInt.toFixed(1)} `;
    }

    // Append last point exactly
    const xLast = width;
    const yPrinLast = 175 - (lastEntry.cumulativePrincipal / maxVal) * 165;
    const yIntLast = 175 - ((lastEntry.cumulativePrincipal + lastEntry.cumulativeInterest) / maxVal) * 165;
    prinPoints += `L ${xLast} ${yPrinLast.toFixed(1)}`;
    intPoints += `L ${xLast} ${yIntLast.toFixed(1)}`;

    document.getElementById('area-line-principal')?.setAttribute('d', prinPoints);
    document.getElementById('area-line-interest')?.setAttribute('d', intPoints);

    document.getElementById('area-path-principal')?.setAttribute('d', `${prinPoints} L ${width} 175 L 0 175 Z`);
    document.getElementById('area-path-interest')?.setAttribute('d', `${intPoints} L ${width} 175 L 0 175 Z`);

    // Render baseline comparison lines if toggled
    const baseInterestPath = document.getElementById('area-line-baseline-interest');
    const basePrincipalPath = document.getElementById('area-line-baseline-principal');

    if (showBase && globalBaselineSchedule.length > 0) {
      let basePrinPoints = "";
      let baseIntPoints = "";
      const baseMonths = globalBaselineSchedule.length;
      const baseStep = Math.max(1, Math.floor(baseMonths / 60));

      for (let i = 0; i < baseMonths; i += baseStep) {
        const entry = globalBaselineSchedule[i];
        const x = (i / (baseMonths - 1)) * width;
        const yPrin = 175 - (entry.cumulativePrincipal / maxVal) * 165;
        const yInt = 175 - ((entry.cumulativePrincipal + entry.cumulativeInterest) / maxVal) * 165;

        const prefix = i === 0 ? "M" : "L";
        basePrinPoints += `${prefix} ${x.toFixed(1)} ${yPrin.toFixed(1)} `;
        baseIntPoints += `${prefix} ${x.toFixed(1)} ${yInt.toFixed(1)} `;
      }

      // Append baseline final points
      const baseLast = globalBaselineSchedule[baseMonths - 1];
      const basePrinLast = 175 - (baseLast.cumulativePrincipal / maxVal) * 165;
      const baseIntLast = 175 - ((baseLast.cumulativePrincipal + baseLast.cumulativeInterest) / maxVal) * 165;
      basePrinPoints += `L ${width} ${basePrinLast.toFixed(1)}`;
      baseIntPoints += `L ${width} ${baseIntLast.toFixed(1)}`;

      baseInterestPath?.setAttribute('d', baseIntPoints);
      basePrincipalPath?.setAttribute('d', basePrinPoints);
      baseInterestPath?.classList.remove('hidden');
      basePrincipalPath?.classList.remove('hidden');
    } else {
      baseInterestPath?.classList.add('hidden');
      basePrincipalPath?.classList.add('hidden');
    }

    updateLiveRegion(`Equity accumulation area chart. Cumulative payments reach a total of $${Math.round(maxVal).toLocaleString('en-US')} over the duration of the loan. Principal paid is $${Math.round(lastEntry.cumulativePrincipal).toLocaleString('en-US')}, and interest paid is $${Math.round(lastEntry.cumulativeInterest).toLocaleString('en-US')}.`);
  }

  // 3. Line Renderer
  function renderLineSVG() {
    if (globalSchedule.length === 0) return;
    const svg = document.getElementById('line-svg');
    if (!svg) return;

    const width = 400;
    const totalMonths = globalSchedule.length;
    const totalYears = Math.ceil(totalMonths / 12);
    
    // Draw vertical grids and labels
    drawGridAndLabels('line', totalYears);

    const showBase = compareCheckbox?.checked && globalBaselineSchedule.length > 0;
    const maxVal = Math.max(
      globalSchedule[0].remainingBalance,
      showBase ? globalBaselineSchedule[0].remainingBalance : 0
    );

    let points = "";
    const step = Math.max(1, Math.floor(totalMonths / 60));

    for (let i = 0; i < totalMonths; i += step) {
      const entry = globalSchedule[i];
      const x = (i / (totalMonths - 1)) * width;
      const y = 175 - (entry.remainingBalance / maxVal) * 165;
      points += `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)} `;
    }
    
    // Add final point exactly
    const lastX = width;
    const lastY = 175 - (globalSchedule[totalMonths - 1].remainingBalance / maxVal) * 165;
    points += `L ${lastX} ${lastY.toFixed(1)}`;

    document.getElementById('line-path-curve')?.setAttribute('d', points);
    document.getElementById('line-path-area')?.setAttribute('d', `${points} L ${width} 175 L 0 175 Z`);

    // Render baseline curve overlay
    const baseCurvePath = document.getElementById('line-path-baseline');
    if (showBase && globalBaselineSchedule.length > 0) {
      let basePoints = "";
      const baseMonths = globalBaselineSchedule.length;
      const baseStep = Math.max(1, Math.floor(baseMonths / 60));

      for (let i = 0; i < baseMonths; i += baseStep) {
        const entry = globalBaselineSchedule[i];
        const x = (i / (baseMonths - 1)) * width;
        const y = 175 - (entry.remainingBalance / maxVal) * 165;
        basePoints += `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)} `;
      }
      const baseLastY = 175 - (globalBaselineSchedule[baseMonths - 1].remainingBalance / maxVal) * 165;
      basePoints += `L ${width} ${baseLastY.toFixed(1)}`;

      baseCurvePath?.setAttribute('d', basePoints);
      baseCurvePath?.classList.remove('hidden');
    } else {
      baseCurvePath?.classList.add('hidden');
    }

    updateLiveRegion(`Outstanding loan balance reduction line chart. Starting loan balance of $${Math.round(maxVal).toLocaleString('en-US')} declines over the amortization term of the mortgage to zero.`);
  }

  // 4. Bar Renderer (Yearly Split)
  function renderBarSVG() {
    const barSvg = document.getElementById('bar-svg');
    if (!barSvg || globalSchedule.length === 0) return;

    barSvg.innerHTML = ""; // Clear existing bars
    const totalMonths = globalSchedule.length;
    const totalYears = Math.ceil(totalMonths / 12);
    
    // Aggregate by year
    const yearlyData: { principal: number; interest: number }[] = [];
    for (let y = 0; y < totalYears; y++) {
      let annualPrin = 0;
      let annualInt = 0;
      for (let m = 0; m < 12; m++) {
        const idx = y * 12 + m;
        if (idx < totalMonths) {
          annualPrin += globalSchedule[idx].principalPaid + globalSchedule[idx].extraPaid;
          annualInt += globalSchedule[idx].interestPaid;
        }
      }
      yearlyData.push({ principal: annualPrin, interest: annualInt });
    }

    // Baseline aggregation if toggled
    const showBase = compareCheckbox?.checked && globalBaselineSchedule.length > 0;
    const baseYearlyData: { total: number }[] = [];
    if (showBase) {
      const baseMonths = globalBaselineSchedule.length;
      const baseYears = Math.ceil(baseMonths / 12);
      for (let y = 0; y < baseYears; y++) {
        let annualTotal = 0;
        for (let m = 0; m < 12; m++) {
          const idx = y * 12 + m;
          if (idx < baseMonths) {
            annualTotal += globalBaselineSchedule[idx].principalPaid + globalBaselineSchedule[idx].interestPaid;
          }
        }
        baseYearlyData.push({ total: annualTotal });
      }
    }

    const maxYearPI = Math.max(
      ...yearlyData.map(d => d.principal + d.interest),
      showBase ? Math.max(...baseYearlyData.map(d => d.total), 0) : 0
    );
    if (maxYearPI <= 0) return;

    // Draw baseline grid lines and X-axis border
    const isMobile = window.innerWidth < 640;
    const interval = isMobile ? 10 : 5;

    // Draw Axis line
    const axisLine = document.createElementNS("http://www.w3.org/2000/svg", "line");
    axisLine.setAttribute("x1", "0");
    axisLine.setAttribute("y1", "175");
    axisLine.setAttribute("x2", "400");
    axisLine.setAttribute("y2", "175");
    axisLine.setAttribute("stroke", "var(--border-subtle)");
    axisLine.setAttribute("stroke-width", "1");
    barSvg.appendChild(axisLine);

    // Draw grid lines and ticks
    const maxYearLabels = Math.max(totalYears, showBase ? baseYearlyData.length : 0);
    
    // Always render Year 0 label
    const text0 = document.createElementNS("http://www.w3.org/2000/svg", "text");
    text0.setAttribute("x", "4");
    text0.setAttribute("y", "192");
    text0.setAttribute("text-anchor", "start");
    text0.setAttribute("fill", "var(--text-muted)");
    text0.setAttribute("font-size", "8px");
    text0.setAttribute("font-family", "var(--font-sans)");
    text0.setAttribute("font-weight", "500");
    text0.textContent = "Yr 0";
    barSvg.appendChild(text0);

    for (let y = interval; y <= maxYearLabels; y += interval) {
      const x = (y / maxYearLabels) * 400;

      const gridL = document.createElementNS("http://www.w3.org/2000/svg", "line");
      gridL.setAttribute("x1", String(x));
      gridL.setAttribute("y1", "10");
      gridL.setAttribute("x2", String(x));
      gridL.setAttribute("y2", "175");
      gridL.setAttribute("stroke", "var(--border-subtle)");
      gridL.setAttribute("stroke-width", "0.5");
      gridL.setAttribute("stroke-dasharray", "2 2");
      barSvg.appendChild(gridL);

      const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
      text.setAttribute("x", String(x));
      text.setAttribute("y", "192");
      if (y === maxYearLabels) {
        text.setAttribute("x", "396");
        text.setAttribute("text-anchor", "end");
      } else {
        text.setAttribute("text-anchor", "middle");
      }
      text.setAttribute("fill", "var(--text-muted)");
      text.setAttribute("font-size", "8px");
      text.setAttribute("font-family", "var(--font-sans)");
      text.setAttribute("font-weight", "500");
      text.textContent = `Yr ${y}`;
      barSvg.appendChild(text);
    }

    const width = 400;
    const height = 175; // baseline y-axis position
    const barWidth = Math.max(2, (width / maxYearLabels) - 2);

    yearlyData.forEach((data, index) => {
      const x = (index / maxYearLabels) * width + 1;
      
      const totalH = ((data.principal + data.interest) / maxYearPI) * 165;
      const prinH = (data.principal / maxYearPI) * 165;
      const intH = (data.interest / maxYearPI) * 165;

      // Draw interest bar (bottom segment)
      const rectInt = document.createElementNS("http://www.w3.org/2000/svg", "rect");
      rectInt.setAttribute("x", String(x));
      rectInt.setAttribute("y", String(height - intH));
      rectInt.setAttribute("width", String(barWidth));
      rectInt.setAttribute("height", String(intH));
      rectInt.setAttribute("fill", "#f59e0b");
      rectInt.setAttribute("opacity", "0.85");
      barSvg.appendChild(rectInt);

      // Draw principal bar (stacked segment on top of interest)
      const rectPrin = document.createElementNS("http://www.w3.org/2000/svg", "rect");
      rectPrin.setAttribute("x", String(x));
      rectPrin.setAttribute("y", String(height - intH - prinH));
      rectPrin.setAttribute("width", String(barWidth));
      rectPrin.setAttribute("height", String(prinH));
      rectPrin.setAttribute("fill", "#10b981");
      rectPrin.setAttribute("opacity", "0.85");
      barSvg.appendChild(rectPrin);

      // Draw baseline overlay outline if comparison is toggled
      if (showBase && baseYearlyData[index]) {
        const baseH = (baseYearlyData[index].total / maxYearPI) * 165;
        const rectBase = document.createElementNS("http://www.w3.org/2000/svg", "rect");
        rectBase.setAttribute("x", String(x));
        rectBase.setAttribute("y", String(height - baseH));
        rectBase.setAttribute("width", String(barWidth));
        rectBase.setAttribute("height", String(baseH));
        rectBase.setAttribute("fill", "transparent");
        rectBase.setAttribute("stroke", "var(--text-muted)");
        rectBase.setAttribute("stroke-width", "1");
        rectBase.setAttribute("stroke-dasharray", "2 2");
        rectBase.setAttribute("opacity", "0.65");
        barSvg.appendChild(rectBase);
      }

      // Bind tooltip events to rect bars
      const showTooltip = (e: MouseEvent) => {
        const year = index + 1;
        const total = data.principal + data.interest;
        
        let baseHtml = "";
        if (showBase && baseYearlyData[index]) {
          baseHtml = `
            <div class="border-t border-border-subtle pt-1 mt-1 opacity-85">
              <div class="text-text-muted font-bold">Baseline Track</div>
              <div>Total Payment: <span class="text-text-main font-semibold">$${Math.round(baseYearlyData[index].total).toLocaleString('en-US')}</span></div>
            </div>
          `;
        }

        if (tooltip) {
          tooltip.innerHTML = `
            <div class="space-y-0.5">
              <div class="text-text-muted font-bold">Year ${year}</div>
              <div class="text-brand-accent font-bold">Proposed Track</div>
              <div>Principal: <span class="text-emerald-500 font-semibold">$${Math.round(data.principal).toLocaleString('en-US')}</span></div>
              <div>Interest: <span class="text-amber-500 font-semibold">$${Math.round(data.interest).toLocaleString('en-US')}</span></div>
              <div class="border-t border-border-subtle pt-0.5">Total: <span class="text-text-main font-bold">$${Math.round(total).toLocaleString('en-US')}</span></div>
              ${baseHtml}
            </div>
          `;
          tooltip.classList.remove('hidden');
          
          const container = document.getElementById('platform-visualizer');
          if (container) {
            const containerRect = container.getBoundingClientRect();
            const parentLeft = e.clientX - containerRect.left;
            const parentTop = height - totalH - 25; // Align stable above bar
            
            const constrainedLeft = Math.max(12, Math.min(parentLeft + 12, containerRect.width - 210));
            tooltip.style.left = `${constrainedLeft}px`;
            tooltip.style.top = `${parentTop}px`;
          }
        }
      };

      const hideTooltip = () => {
        if (tooltip) tooltip.classList.add('hidden');
      };

      rectInt.addEventListener('mousemove', showTooltip);
      rectInt.addEventListener('mouseleave', hideTooltip);
      rectPrin.addEventListener('mousemove', showTooltip);
      rectPrin.addEventListener('mouseleave', hideTooltip);
    });

    updateLiveRegion(`Yearly split of mortgage payments bar chart. Principal and interest splits are calculated and drawn for each year of the ${maxYearLabels} year mortgage term.`);
  }

  // 5. Timeline Renderer (Milestones)
  function renderTimelineData() {
    if (globalSchedule.length === 0) return;
    
    const totalMonths = globalSchedule.length;
    const origPrincipal = globalSchedule[0].remainingBalance + globalSchedule[0].principalPaid;
    
    // Find half principal paid month
    let halfPaidMonth = -1;
    for (let i = 0; i < totalMonths; i++) {
      if (globalSchedule[i].remainingBalance <= origPrincipal * 0.5) {
        halfPaidMonth = i + 1;
        break;
      }
    }

    // Find PMI Cancel Month
    let pmiCancelMonth = -1;
    for (let i = 0; i < totalMonths; i++) {
      if (globalSchedule[i].pmiPaid === 0 && i > 0 && globalSchedule[i-1].pmiPaid > 0) {
        pmiCancelMonth = i;
        break;
      }
    }

    // Update nodes labels
    const pmiNode = document.getElementById('milestone-pmi-node');
    const pmiTime = document.getElementById('timeline-pmi-time');
    if (pmiTime) {
      if (pmiCancelMonth > 0) {
        if (pmiNode) pmiNode.style.display = 'block';
        const yrs = (pmiCancelMonth / 12).toFixed(1);
        pmiTime.textContent = `Month ${pmiCancelMonth} (~${yrs} yrs)`;
      } else {
        // Hide PMI node if no PMI was charged
        if (pmiNode) pmiNode.style.display = 'none';
      }
    }

    const halfTime = document.getElementById('timeline-half-time');
    if (halfTime && halfPaidMonth > 0) {
      const yrs = (halfPaidMonth / 12).toFixed(1);
      halfTime.textContent = `Month ${halfPaidMonth} (~${yrs} yrs)`;
    }

    const payoffTime = document.getElementById('timeline-payoff-time');
    if (payoffTime) {
      const yrs = (totalMonths / 12).toFixed(1);
      payoffTime.textContent = `Month ${totalMonths} (${yrs} yrs)`;
    }

    // Update Timeline Description with Comparison insights
    const desc = document.getElementById('timeline-insights-desc');
    if (desc) {
      let insightHtml = `You will reach <strong>50% principal equity</strong> in Month ${halfPaidMonth} (~${(halfPaidMonth / 12).toFixed(1)} years).`;
      if (pmiCancelMonth > 0) {
        insightHtml += ` Private Mortgage Insurance (PMI) is scheduled to terminate at <strong>Month ${pmiCancelMonth}</strong>, reducing your housing expenses instantly.`;
      }
      insightHtml += ` Total debt freedom is achieved in <strong>${(totalMonths / 12).toFixed(1)} years</strong>.`;
      
      const showBase = compareCheckbox?.checked && globalBaselineSchedule.length > 0;
      if (showBase) {
        const baseMonths = globalBaselineSchedule.length;
        const diffMonths = baseMonths - totalMonths;
        if (diffMonths > 0) {
          const diffYrs = (diffMonths / 12).toFixed(1);
          insightHtml += ` <span class="text-emerald-500 font-semibold block mt-1">Comparison Insight: This proposed plan pays off the loan ${diffMonths} months (~${diffYrs} years) faster than remaining on the baseline path.</span>`;
        }
      }
      desc.innerHTML = insightHtml;
    }
  }
</script>

