---
---
<div class="rounded-xl border border-border-subtle bg-bg-card p-6 space-y-4">
  <div class="flex justify-between items-start">
    <div>
      <h3 class="font-display text-sm font-semibold text-text-main">Debt-to-Income (DTI) Stress Gauge</h3>
      <p class="text-xs text-text-muted mt-1">Based on the traditional financial 28/36 lending rule.</p>
    </div>
    <div class="text-right">
      <span class="inline-flex items-center rounded-full px-2 py-0.5 text-2xs font-medium border" id="dti-badge">
        Calculating...
      </span>
    </div>
  </div>

  <!-- Progress Bar Gauge -->
  <div class="space-y-2">
    <div class="relative h-2 w-full overflow-hidden rounded-full bg-border-subtle flex">
      <div class="h-full bg-emerald-500 w-[28%]" title="Comfortable (Under 28%)"></div>
      <div class="h-full bg-amber-500 w-[8%]" title="Stretch (28% - 36%)"></div>
      <div class="h-full bg-rose-500 w-[64%]" title="Danger Zone (Over 36%)"></div>
      
      <!-- Indicator Needle -->
      <div class="absolute top-0 bottom-0 w-1 bg-white shadow-md transition-all duration-300" id="dti-pointer" style="left: 0%;"></div>
    </div>
    
    <div class="flex justify-between text-3xs text-text-muted font-mono">
      <span>0%</span>
      <span class="text-emerald-500 dark:text-emerald-400">28% (Housing Cap)</span>
      <span class="text-amber-500 dark:text-amber-400">36% (Total Debt Cap)</span>
      <span>100%</span>
    </div>
  </div>

  <!-- Realtime calculation readouts -->
  <div class="grid grid-cols-2 gap-4 pt-2 border-t border-border-subtle text-xs">
    <div>
      <span class="text-text-muted block">Front-End (Housing DTI)</span>
      <span class="font-semibold text-text-main font-tabular" id="dti-frontend-val">0.0%</span>
    </div>
    <div>
      <span class="text-text-muted block">Back-End (Total Debt DTI)</span>
      <span class="font-semibold text-text-main font-tabular" id="dti-backend-val">0.0%</span>
    </div>
  </div>

  <!-- Text descriptions dynamic -->
  <div class="rounded-lg bg-bg-main border border-border-subtle p-3 text-xs text-text-muted" id="dti-description">
    Loading assessment...
  </div>
</div>

<script>
  window.updateDTIGauge = function(housingPayment: number, otherDebts: number, annualIncome: number) {
    const grossMonthlyIncome = annualIncome / 12;
    
    const frontendDTI = grossMonthlyIncome > 0 ? (housingPayment / grossMonthlyIncome) * 100 : 0;
    const backendDTI = grossMonthlyIncome > 0 ? ((housingPayment + otherDebts) / grossMonthlyIncome) * 100 : 0;
    
    // Update labels
    const frontendEl = document.getElementById('dti-frontend-val');
    const backendEl = document.getElementById('dti-backend-val');
    if (frontendEl) frontendEl.textContent = `${frontendDTI.toFixed(1)}%`;
    if (backendEl) backendEl.textContent = `${backendDTI.toFixed(1)}%`;
    
    // Set DTI gauge pointer based on backend DTI
    const pointer = document.getElementById('dti-pointer');
    if (pointer) {
      // Map DTI percentage 0-50% to left offset 0-100%
      const leftOffset = Math.min(100, Math.max(0, (backendDTI / 50) * 100));
      pointer.style.left = `${leftOffset}%`;
    }
    
    // Set description and badge
    const badge = document.getElementById('dti-badge');
    const desc = document.getElementById('dti-description');
    
    if (badge && desc) {
      if (backendDTI <= 28) {
        badge.textContent = "Comfortable";
        badge.className = "inline-flex items-center rounded-full px-2 py-0.5 text-2xs font-medium border border-emerald-500/30 bg-emerald-500/10 text-emerald-700 dark:text-emerald-400";
        desc.innerHTML = `Your monthly housing and overall debt costs are well within safe lending limits. Lenders consider this DTI highly favorable, which helps secure the best interest rates.`;
      } else if (backendDTI <= 36) {
        badge.textContent = "Stretch";
        badge.className = "inline-flex items-center rounded-full px-2 py-0.5 text-2xs font-medium border border-amber-500/30 bg-amber-500/10 text-amber-800 dark:text-amber-400";
        desc.innerHTML = `Your budget is in the <strong>Stretch Zone</strong>. While standard conventional mortgages allow DTIs up to 36% (and occasionally higher), you will have less financial buffer for savings or discretionary spending.`;
      } else {
        badge.textContent = "Danger Zone";
        badge.className = "inline-flex items-center rounded-full px-2 py-0.5 text-2xs font-medium border border-rose-500/30 bg-rose-500/10 text-rose-700 dark:text-rose-400";
        desc.innerHTML = `Your estimated DTI is in the <strong>Danger Zone (${backendDTI.toFixed(1)}%)</strong>. Most lenders limit standard loans to 36% DTI. You may need to increase your down payment, reduce other debts, or target a lower home price to qualify.`;
      }
    }
  };
</script>
