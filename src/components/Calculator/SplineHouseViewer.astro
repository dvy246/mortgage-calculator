---
---

<div id="spline-showcase-container" class="rounded-xl border border-border-subtle bg-bg-card p-5 space-y-4 shadow-sm relative overflow-hidden group">
  <div class="absolute top-0 left-0 w-full h-1 bg-brand-accent"></div>
  <div class="flex justify-between items-center">
    <div>
      <h3 class="font-display text-sm font-semibold text-text-main flex items-center gap-1.5">
        <svg class="h-4 w-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2-2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        <span>House System Anatomy & 3D Viewer</span>
      </h3>
      <p class="text-3xs text-text-muted mt-0.5">Click parts to inspect maintenance sinking funds</p>
    </div>
    
    <button 
      id="btn-toggle-3d" 
      class="inline-flex h-7 items-center justify-center rounded-md border border-border-subtle bg-bg-main hover:bg-bg-card-hover px-3 text-3xs font-semibold text-text-main transition-all cursor-pointer focus:outline-none focus:ring-1 focus:ring-brand-accent"
      aria-label="Load interactive 3D model"
    >
      Load 3D View
    </button>
  </div>

  <!-- Main visual canvas viewport -->
  <div class="relative w-full h-56 rounded-lg bg-bg-main border border-border-subtle overflow-hidden flex items-center justify-center">
    
    <!-- 2D Isometric Interactive SVG Placeholder -->
    <div id="spline-placeholder" class="w-full h-full flex flex-col items-center justify-center p-4 transition-opacity duration-300">
      <svg viewBox="0 0 200 160" class="w-full max-h-48 drop-shadow-md">
        <!-- Base Land -->
        <polygon points="20,130 100,90 180,130 100,150" class="fill-bg-card stroke-border-subtle" stroke-width="1.5" />
        <polygon points="20,130 100,150 100,156 20,136" class="fill-border-subtle/40" />
        <polygon points="100,150 180,130 180,136 100,156" class="fill-border-subtle/20" />
        
        <!-- House Body Walls -->
        <!-- Left Wall -->
        <polygon points="40,110 90,85 90,125 40,138" class="fill-bg-card hover:fill-bg-card-hover stroke-border-subtle cursor-pointer transition-colors" stroke-width="1.5" />
        <!-- Right Wall -->
        <polygon points="90,85 160,110 160,138 90,125" class="fill-bg-card hover:fill-bg-card-hover stroke-border-subtle cursor-pointer transition-colors" stroke-width="1.5" />
        
        <!-- Interactive Roof (Hotspot) -->
        <g id="svg-hotspot-roof" class="cursor-pointer group/roof transition-all">
          <polygon points="40,110 90,85 100,55 50,75" class="fill-rose-500/10 group-hover/roof:fill-rose-500/30 stroke-rose-500/80 transition-colors" stroke-width="1.5" />
          <polygon points="90,85 160,110 150,75 100,55" class="fill-rose-500/15 group-hover/roof:fill-rose-500/35 stroke-rose-500/80 transition-colors" stroke-width="1.5" />
          <text x="100" y="45" class="fill-rose-500 font-display text-[8px] font-bold text-center pointer-events-none opacity-0 group-hover/roof:opacity-100 transition-opacity" text-anchor="middle">Roof System</text>
        </g>
        
        <!-- Interactive HVAC Compressor Unit (Hotspot) -->
        <g id="svg-hotspot-hvac" class="cursor-pointer group/hvac transition-all">
          <!-- Small Box next to the house -->
          <polygon points="140,125 155,118 155,130 140,135" class="fill-blue-500/20 group-hover/hvac:fill-blue-500/40 stroke-blue-500/90 transition-colors" stroke-width="1" />
          <polygon points="155,118 170,123 170,133 155,130" class="fill-blue-500/30 group-hover/hvac:fill-blue-500/50 stroke-blue-500/90 transition-colors" stroke-width="1" />
          <polygon points="140,125 155,118 170,123 155,130" class="fill-blue-500/25 group-hover/hvac:fill-blue-500/45 stroke-blue-500/90 transition-colors" stroke-width="1" />
          <!-- Fan blades detail -->
          <circle cx="155" cy="122" r="2.5" class="fill-blue-400/50 animate-pulse" />
          <text x="175" y="115" class="fill-blue-500 font-display text-[8px] font-bold pointer-events-none opacity-0 group-hover/hvac:opacity-100 transition-opacity" text-anchor="start">HVAC System</text>
        </g>
        
        <!-- Interactive Water Heater / Plumbing (Hotspot) -->
        <g id="svg-hotspot-water" class="cursor-pointer group/water transition-all">
          <!-- Cylinder icon inside or placed on side -->
          <rect x="60" y="100" width="10" height="20" rx="3" class="fill-amber-500/20 group-hover/water:fill-amber-500/45 stroke-amber-500/90 transition-colors" stroke-width="1" />
          <line x1="62" y1="105" x2="68" y2="105" class="stroke-amber-500/80" stroke-width="0.8" />
          <line x1="62" y1="110" x2="68" y2="110" class="stroke-amber-500/80" stroke-width="0.8" />
          <text x="50" y="95" class="fill-amber-500 font-display text-[8px] font-bold pointer-events-none opacity-0 group-hover/water:opacity-100 transition-opacity" text-anchor="middle">Water Heater</text>
        </g>

        <!-- Interactive Kitchen Appliances (Hotspot) -->
        <g id="svg-hotspot-appliances" class="cursor-pointer group/appliances transition-all">
          <!-- A window grid representing kitchen -->
          <polygon points="105,100 120,105 120,118 105,112" class="fill-emerald-500/10 group-hover/appliances:fill-emerald-500/35 stroke-emerald-500/80 transition-all" stroke-width="1" />
          <line x1="112.5" y1="102.5" x2="112.5" y2="115" class="stroke-emerald-500/70" stroke-width="0.8" />
          <line x1="105" y1="109" x2="120" y2="111.5" class="stroke-emerald-500/70" stroke-width="0.8" />
          <text x="125" y="95" class="fill-emerald-500 font-display text-[8px] font-bold pointer-events-none opacity-0 group-hover/appliances:opacity-100 transition-opacity" text-anchor="start">Appliances</text>
        </g>
      </svg>
      <span class="text-4xs text-text-muted mt-2 block select-none">Hover/Tap highlights maintenance modules</span>
    </div>

    <!-- 3D Canvas element wrapper, dynamically loaded -->
    <div id="spline-3d-wrapper" class="absolute inset-0 w-full h-full opacity-0 pointer-events-none transition-opacity duration-500 flex items-center justify-center">
      <div id="spline-loading-indicator" class="absolute text-2xs text-text-muted font-semibold flex items-center gap-2">
        <svg class="animate-spin h-4 w-4 text-brand-accent" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>Loading 3D Canvas...</span>
      </div>
      <!-- Built-in spline-viewer web component is mounted here -->
    </div>

  </div>
</div>

<script>
  let splineScriptLoaded = false;
  let is3DActive = false;

  const btnToggle3D = document.getElementById('btn-toggle-3d');
  const splinePlaceholder = document.getElementById('spline-placeholder');
  const spline3DWrapper = document.getElementById('spline-3d-wrapper');
  const splineLoadingIndicator = document.getElementById('spline-loading-indicator');

  // Interactive 2D SVG triggers
  const hotspotRoof = document.getElementById('svg-hotspot-roof');
  const hotspotHVAC = document.getElementById('svg-hotspot-hvac');
  const hotspotWater = document.getElementById('svg-hotspot-water');
  const hotspotAppliances = document.getElementById('svg-hotspot-appliances');

  function scrollAndHighlightInput(inputId: string) {
    const inputEl = document.getElementById(inputId);
    if (inputEl) {
      inputEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      // Apply a temporary highlight ring
      const parentCard = inputEl.closest('.space-y-2.5') || inputEl.closest('.grid') || inputEl;
      parentCard.classList.add('ring-2', 'ring-brand-accent', 'transition-all');
      setTimeout(() => {
        parentCard.classList.remove('ring-2', 'ring-brand-accent');
      }, 2000);
    }
  }

  // Bind 2D events
  hotspotRoof?.addEventListener('click', () => scrollAndHighlightInput('age-roof'));
  hotspotHVAC?.addEventListener('click', () => scrollAndHighlightInput('age-hvac'));
  hotspotWater?.addEventListener('click', () => scrollAndHighlightInput('age-water'));
  hotspotAppliances?.addEventListener('click', () => scrollAndHighlightInput('age-appliances'));

  // Load Spline Viewer dynamically
  async function loadSpline3D() {
    if (is3DActive) return;
    is3DActive = true;
    
    if (btnToggle3D) {
      btnToggle3D.textContent = '3D Mode';
      btnToggle3D.classList.add('bg-brand-accent/15', 'border-brand-accent/50', 'text-brand-accent');
    }

    // Show wrapper, hide 2D placeholder
    if (spline3DWrapper) {
      spline3DWrapper.classList.remove('pointer-events-none');
      spline3DWrapper.classList.add('opacity-100');
    }
    if (splinePlaceholder) {
      splinePlaceholder.classList.add('opacity-0', 'pointer-events-none');
    }

    if (!splineScriptLoaded) {
      // Inject CDN Script
      const script = document.createElement('script');
      script.type = 'module';
      script.src = 'https://unpkg.com/@splinetool/viewer@1.9.0/build/spline-viewer.js';
      
      script.onload = () => {
        mountSplineViewer();
      };
      script.onerror = () => {
        if (splineLoadingIndicator) {
          splineLoadingIndicator.innerHTML = '<span class="text-danger font-semibold">Network Error. Falling back to 2D.</span>';
        }
        setTimeout(fallbackTo2D, 2500);
      };
      
      document.body.appendChild(script);
      splineScriptLoaded = true;
    } else {
      mountSplineViewer();
    }
  }

  function mountSplineViewer() {
    if (!spline3DWrapper) return;
    
    // Create spline-viewer custom element
    const viewer = document.createElement('spline-viewer');
    // Using a beautiful 3D house model scene designed for interactive controls
    viewer.setAttribute('url', 'https://prod.spline.design/iK-1mRk2BvE0lJn3/scene.splinecode');
    viewer.setAttribute('render-on-demand', 'true');
    
    // Once loaded event
    viewer.addEventListener('load-complete', () => {
      if (splineLoadingIndicator) splineLoadingIndicator.classList.add('hidden');
    });

    // Handle interactive event clicks from 3D Spline scene
    // Note: The object names match 'Roof', 'HVAC', 'WaterHeater', 'Appliances' in the 3D Spline scene.
    viewer.addEventListener('mouseDown', (e: any) => {
      const objName = e.detail?.name;
      if (!objName) return;
      if (objName.toLowerCase().includes('roof')) {
        scrollAndHighlightInput('age-roof');
      } else if (objName.toLowerCase().includes('hvac') || objName.toLowerCase().includes('ac')) {
        scrollAndHighlightInput('age-hvac');
      } else if (objName.toLowerCase().includes('water') || objName.toLowerCase().includes('heater')) {
        scrollAndHighlightInput('age-water');
      } else if (objName.toLowerCase().includes('appliance') || objName.toLowerCase().includes('kitchen')) {
        scrollAndHighlightInput('age-appliances');
      }
    });

    spline3DWrapper.appendChild(viewer);
  }

  function fallbackTo2D() {
    is3DActive = false;
    if (btnToggle3D) {
      btnToggle3D.textContent = 'Load 3D View';
      btnToggle3D.classList.remove('bg-brand-accent/15', 'border-brand-accent/50', 'text-brand-accent');
    }
    if (spline3DWrapper) {
      spline3DWrapper.classList.remove('opacity-100');
      spline3DWrapper.classList.add('pointer-events-none');
    }
    if (splinePlaceholder) {
      splinePlaceholder.classList.remove('opacity-0', 'pointer-events-none');
    }
  }

  // Lazy Load via IntersectionObserver (triggers on scroll if user doesn't click toggle)
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Pre-fetch the script to cache it, but do not mount viewer yet until clicked or hovered
        if (!splineScriptLoaded) {
          const prefetchLink = document.createElement('link');
          prefetchLink.rel = 'prefetch';
          prefetchLink.href = 'https://unpkg.com/@splinetool/viewer@1.9.0/build/spline-viewer.js';
          document.head.appendChild(prefetchLink);
          splineScriptLoaded = true;
        }
        observer.unobserve(entry.target);
      }
    });
  }, { rootMargin: '100px' });

  const container = document.getElementById('spline-showcase-container');
  if (container) observer.observe(container);

  btnToggle3D?.addEventListener('click', loadSpline3D);
</script>
