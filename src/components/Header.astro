---
import { guidesDatabase } from '../data/guides';
import { comparisons } from '../data/comparisons';

interface Props {
  activeSlug?: string;
}
const { activeSlug } = Astro.props;

interface SearchItem {
  title: string;
  url: string;
  category: string;
  description: string;
}

const searchIndex: SearchItem[] = [];

const calcItems: SearchItem[] = [
  { title: "Mortgage Options Explorer", url: "/mortgage-blueprint", category: "Calculator", description: "Compare conventional, FHA, VA, USDA, and jumbo loans side by side" },
  { title: "Rent vs Buy Calculator", url: "/rent-vs-buy-calculator", category: "Calculator", description: "Compare renting vs buying with break-even analysis and after-tax estimates" },
  { title: "Mortgage Readiness Score", url: "/mortgage-readiness-score", category: "Calculator", description: "5-dimension readiness estimate — income, debt, savings, credit, market" },
  { title: "House Affordability Calculator", url: "/house-affordability-calculator", category: "Calculator", description: "Determine your maximum home purchase price based on income and DTI" },
  { title: "Mortgage Payoff Calculator", url: "/mortgage-payoff-calculator", category: "Calculator", description: "Full amortization schedule and equity milestones" },
  { title: "Extra Payment Calculator", url: "/extra-payment-calculator", category: "Calculator", description: "Interest savings and term reduction from prepayments" },
  { title: "Refinance Calculator", url: "/refinance-calculator", category: "Calculator", description: "Break-even analysis and lifetime savings" },
  { title: "PMI Calculator", url: "/mortgage-calculator-with-pmi", category: "Calculator", description: "PMI cost estimation and cancellation milestones" },
  { title: "Lender Fee Auditor", url: "/lender-fee-auditor", category: "Calculator", description: "Audit closing costs and generate negotiation scripts" },
  { title: "CapEx Planner", url: "/homeownership-capex-planner", category: "Calculator", description: "30-year home maintenance sinking fund targets" },
  { title: "Co-Buying Equity Splitter", url: "/co-buying-equity-splitter", category: "Calculator", description: "Dynamic equity splits for unequal co-buyer contributions" }
];
searchIndex.push(...calcItems);

const guideSlugMap: Record<string, string> = {
  "first-time": "first-time-home-buyer-guide",
  "pmi-removal": "pmi-removal-guide",
  "fha-vs-conv": "fha-vs-conventional-loans",
  "closing-costs": "mortgage-closing-costs-explained",
  "state-rates": "average-mortgage-rates-by-state",
  "mortgage-rates": "mortgage-rates-guide",
  "conforming-loans": "conforming-loans-guide",
  "jumbo-loans": "jumbo-loans-guide",
  "loan-amortization": "loan-amortization-guide",
  "mortgage-points": "mortgage-points-guide",
  "property-taxes-escrow": "property-taxes-escrow-guide",
  "dti-ratio-explained": "dti-ratio-explained-guide",
  "biweekly-payments": "biweekly-payments-guide",
  "lump-sum-prepayment": "lump-sum-prepayment-guide",
  "rate-lock-agreements": "rate-lock-agreements-guide",
  "equity-and-refinance": "equity-and-refinance-guide",
  "refinance-closing-costs": "refinance-closing-costs-guide",
  "hoa-fees-affordability": "hoa-fees-affordability-guide",
  "homeowners-insurance": "homeowners-insurance-guide",
  "credit-score-mortgage": "credit-score-mortgage-guide"
};

for (const [key, guide] of Object.entries(guidesDatabase)) {
  const slug = guideSlugMap[key] || key;
  searchIndex.push({
    title: guide.title,
    url: `/guides/${slug}`,
    category: guide.category,
    description: guide.description
  });
}

for (const comp of comparisons) {
  searchIndex.push({
    title: comp.title,
    url: `/compare/${comp.slug}`,
    category: "Comparison",
    description: comp.description
  });
}

const searchIndexJson = JSON.stringify(searchIndex);
---

<header class="sticky top-0 z-50 w-full border-b border-border-subtle bg-bg-card/85 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-5">
      <a href="/" class="flex items-center gap-2 font-display text-base font-semibold tracking-tight text-text-main transition-opacity hover:opacity-90 shrink-0">
        <svg class="h-5 w-5 text-brand-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        <span class="hidden sm:inline">Mortgage<span class="text-brand-accent">Intelligence</span></span>
        <span class="sm:hidden">MI</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1 text-sm font-medium text-text-muted">
        <!-- Calculators Dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-3 py-1.5 rounded-md transition-colors hover:text-text-main hover:bg-bg-card-hover/50 cursor-pointer">
            Calculators
            <svg class="h-3 w-3 mt-0.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-64 rounded-xl border border-border-subtle bg-bg-card shadow-xl p-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            <div class="space-y-0.5">
              {calcItems.slice(0, 5).map(calc => (
                <a
                  href={calc.url}
                  class={`block px-3 py-2 rounded-lg text-xs transition-colors ${
                    activeSlug === calc.url.split('/')[1] ? "text-text-main bg-bg-card-hover" : "hover:text-text-main hover:bg-bg-card-hover"
                  }`}
                >
                  <span class="font-semibold">{calc.title}</span>
                </a>
              ))}
              <hr class="border-border-subtle my-1" />
              {calcItems.slice(5).map(calc => (
                <a
                  href={calc.url}
                  class="block px-3 py-2 rounded-lg text-xs transition-colors hover:text-text-main hover:bg-bg-card-hover"
                >
                  <span class="font-semibold">{calc.title}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href="/mortgage-blueprint" class={`px-3 py-1.5 rounded-md transition-colors hover:text-text-main ${activeSlug === 'blueprint' ? 'text-text-main bg-bg-card-hover border border-border-subtle' : 'hover:bg-bg-card-hover/50'}`}>
          <span class="inline-flex items-center gap-1.5">
            Options Explorer
            <span class="inline-flex items-center rounded-full bg-blue-500/10 px-1.5 py-0.5 text-4xs font-medium text-blue-500 border border-blue-500/20">New</span>
          </span>
        </a>
        <a href="/mortgage-readiness-score" class={`px-3 py-1.5 rounded-md transition-colors hover:text-text-main ${activeSlug === 'readiness' ? 'text-text-main bg-bg-card-hover border border-border-subtle' : 'hover:bg-bg-card-hover/50'}`}>
          <span class="inline-flex items-center gap-1.5">
            Readiness Score
          </span>
        </a>
        <a href="/compare/" class={`px-3 py-1.5 rounded-md transition-colors hover:text-text-main ${activeSlug === 'compare' ? 'text-text-main bg-bg-card-hover border border-border-subtle' : 'hover:bg-bg-card-hover/50'}`}>Comparisons</a>
        <a href="/guides/" class={`px-3 py-1.5 rounded-md transition-colors hover:text-text-main ${activeSlug === 'guides' ? 'text-text-main bg-bg-card-hover border border-border-subtle' : 'hover:bg-bg-card-hover/50'}`}>Guides</a>
      </nav>
    </div>

    <div class="flex items-center gap-2">
      <!-- Search Button -->
      <button
        id="search-toggle"
        class="p-1.5 rounded-md border border-border-subtle bg-bg-card hover:bg-bg-card-hover text-text-muted hover:text-text-main focus-visible:ring-2 focus-visible:ring-brand-accent focus:outline-none transition-colors cursor-pointer"
        aria-label="Open Search"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="10" cy="10" r="7" /><path stroke-linecap="round" d="M21 21l-6-6" />
        </svg>
      </button>

      <!-- Theme Switcher -->
      <button
        id="theme-toggle"
        class="p-1.5 rounded-md border border-border-subtle bg-bg-card hover:bg-bg-card-hover text-text-muted hover:text-text-main focus-visible:ring-2 focus-visible:ring-brand-accent focus:outline-none transition-colors cursor-pointer"
        aria-label="Toggle theme color"
      >
        <svg id="theme-icon-sun" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" /></svg>
        <svg id="theme-icon-moon" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
      </button>

      <!-- CTA -->
      <a href="/house-affordability-calculator" class="hidden sm:inline-flex h-8 items-center justify-center rounded-md bg-brand-primary px-3 text-xs font-semibold text-bg-main border border-border-subtle transition-all hover:opacity-90 active:scale-[0.98]">
        Check Affordability
      </a>

      <!-- Mobile menu trigger -->
      <button
        class="lg:hidden p-1.5 text-text-muted hover:text-text-main focus:outline-none cursor-pointer"
        id="mobile-menu-toggle"
        aria-label="Toggle Navigation Menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Drawer -->
  <div class="hidden border-b border-border-subtle bg-bg-card px-4 py-4 lg:hidden" id="mobile-menu">
    <!-- Mobile Search -->
    <div class="relative mb-4">
      <input
        type="text"
        id="mobile-search-input"
        placeholder="Search calculators, guides, comparisons..."
        class="h-9 w-full rounded-lg border border-border-input bg-bg-input pl-8 pr-3 text-xs text-text-main placeholder-text-muted/65 focus:border-border-focus focus:outline-none"
        autocomplete="off"
      />
      <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="10" cy="10" r="7" /><path stroke-linecap="round" d="M21 21l-6-6" /></svg>
      <div id="mobile-search-results" class="hidden mt-2 rounded-lg border border-border-subtle bg-bg-card shadow-lg max-h-64 overflow-y-auto"></div>
    </div>

    <nav class="flex flex-col gap-1 text-sm font-medium text-text-muted">
      <span class="text-3xs font-semibold text-text-muted uppercase tracking-wider px-3 py-1">Calculators</span>
      {calcItems.map(calc => (
        <a href={calc.url} class="px-3 py-2 rounded-md transition-colors hover:text-text-main hover:bg-bg-card-hover">{calc.title}</a>
      ))}
      <hr class="border-border-subtle my-2" />
      <a href="/mortgage-blueprint" class="px-3 py-2 rounded-md transition-colors hover:text-text-main hover:bg-bg-card-hover">
        Options Explorer <span class="text-4xs text-blue-500 font-semibold">New</span>
      </a>
      <a href="/rent-vs-buy-calculator" class="px-3 py-2 rounded-md transition-colors hover:text-text-main hover:bg-bg-card-hover">Rent vs Buy Calculator</a>
      <a href="/mortgage-readiness-score" class="px-3 py-2 rounded-md transition-colors hover:text-text-main hover:bg-bg-card-hover">
        Readiness Score
      </a>
      <a href="/compare/" class="px-3 py-2 rounded-md transition-colors hover:text-text-main hover:bg-bg-card-hover">Comparisons</a>
      <a href="/guides/" class="px-3 py-2 rounded-md transition-colors hover:text-text-main hover:bg-bg-card-hover">Guides</a>
      <a href="/glossary" class="px-3 py-2 rounded-md transition-colors hover:text-text-main hover:bg-bg-card-hover">Glossary</a>
    </nav>
  </div>

  <!-- Search Overlay -->
  <div id="search-overlay" class="hidden fixed inset-0 z-50 bg-black/40 backdrop-blur-sm">
    <div class="mx-auto max-w-2xl px-4 pt-[15vh]">
      <div class="rounded-xl border border-border-subtle bg-bg-card shadow-2xl overflow-hidden">
        <div class="relative border-b border-border-subtle">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="10" cy="10" r="7" /><path stroke-linecap="round" d="M21 21l-6-6" /></svg>
          <input
            type="text"
            id="search-input"
            placeholder="Search calculators, guides, comparisons..."
            class="h-12 w-full bg-transparent pl-10 pr-4 text-sm text-text-main placeholder-text-muted/65 focus:outline-none"
            autocomplete="off"
            autofocus
          />
          <button id="search-close" class="absolute right-3 top-1/2 -translate-y-1/2 p-1 rounded-md text-text-muted hover:text-text-main hover:bg-bg-card-hover transition-colors cursor-pointer" aria-label="Close Search">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <div id="search-results" class="max-h-[50vh] overflow-y-auto p-2">
          <div class="p-6 text-center text-xs text-text-muted" id="search-empty-state">
            Type to search calculators, guides, and comparison tools.
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Search index data -->
  <script type="application/json" id="search-index-data" set:html={searchIndexJson}></script>
</header>

<script>
  // --- Search Implementation ---
  const searchToggle = document.getElementById('search-toggle');
  const searchOverlay = document.getElementById('search-overlay');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results');
  const searchClose = document.getElementById('search-close');
  const searchEmpty = document.getElementById('search-empty-state');

  // Mobile search
  const mobileSearchInput = document.getElementById('mobile-search-input') as HTMLInputElement;
  const mobileSearchResults = document.getElementById('mobile-search-results');

  // Load search index
  let searchIndex: { title: string; url: string; category: string; description: string }[] = [];
  try {
    const data = document.getElementById('search-index-data');
    if (data) searchIndex = JSON.parse(data.textContent || '[]');
  } catch (e) { /* silent */ }

  const categoryColors: Record<string, string> = {
    'Calculator': 'bg-blue-500/10 text-blue-500 border-blue-500/20',
    'Comparison': 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20',
    'Home Buying': 'bg-violet-500/10 text-violet-500 border-violet-500/20',
    'Loan Programs': 'bg-amber-500/10 text-amber-500 border-amber-500/20',
    'Mortgage Math': 'bg-rose-500/10 text-rose-500 border-rose-500/20',
    'Escrow': 'bg-cyan-500/10 text-cyan-500 border-cyan-500/20',
    'Debt Management': 'bg-orange-500/10 text-orange-500 border-orange-500/20',
    'Prepayments': 'bg-pink-500/10 text-pink-500 border-pink-500/20',
    'Refinance': 'bg-indigo-500/10 text-indigo-500 border-indigo-500/20',
    'Research & Data': 'bg-slate-500/10 text-slate-500 border-slate-500/20'
  };

  function getCategoryColor(cat: string): string {
    return categoryColors[cat] || 'bg-border-subtle text-text-muted border-border-subtle';
  }

  function performSearch(query: string, container: HTMLElement, emptyEl: HTMLElement | null) {
    const q = query.toLowerCase().trim();
    if (!q) {
      container.innerHTML = '';
      if (emptyEl) {
        emptyEl.textContent = 'Type to search calculators, guides, and comparison tools.';
        container.appendChild(emptyEl);
      }
      return;
    }

    const maxResults = 12;
    const results = searchIndex
      .filter(item => item.title.toLowerCase().includes(q) || item.description.toLowerCase().includes(q))
      .slice(0, maxResults);

    container.innerHTML = '';

    if (results.length === 0) {
      if (emptyEl) {
        emptyEl.textContent = `No results found for "${query}". Try a different term.`;
        container.appendChild(emptyEl);
      }
      return;
    }

    results.forEach(item => {
      const a = document.createElement('a');
      a.href = item.url;
      a.className = 'flex items-start gap-3 p-3 rounded-lg transition-colors hover:bg-bg-card-hover cursor-pointer';
      a.innerHTML = `
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-4xs font-medium border whitespace-nowrap shrink-0 mt-0.5 ${getCategoryColor(item.category)}">
          ${item.category}
        </span>
        <div class="min-w-0">
          <span class="block text-xs font-semibold text-text-main truncate">${escapeHtml(item.title)}</span>
          <span class="block text-3xs text-text-muted truncate mt-0.5">${escapeHtml(item.description)}</span>
        </div>
      `;
      container.appendChild(a);
    });
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Desktop search overlay
  if (searchToggle && searchOverlay && searchInput && searchResults && searchClose) {
    searchToggle.addEventListener('click', () => {
      searchOverlay.classList.remove('hidden');
      setTimeout(() => searchInput.focus(), 100);
      document.body.style.overflow = 'hidden';
    });

    searchClose.addEventListener('click', closeSearch);
    searchOverlay.addEventListener('click', (e) => {
      if (e.target === searchOverlay) closeSearch();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeSearch();
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        if (searchOverlay.classList.contains('hidden')) {
          searchToggle.click();
        } else {
          closeSearch();
        }
      }
    });

    function closeSearch() {
      searchOverlay.classList.add('hidden');
      document.body.style.overflow = '';
      searchInput.value = '';
      performSearch('', searchResults, searchEmpty);
    }

    searchInput.addEventListener('input', () => {
      performSearch(searchInput.value, searchResults, searchEmpty);
    });
  }

  // Mobile search
  if (mobileSearchInput && mobileSearchResults) {
    mobileSearchInput.addEventListener('input', () => {
      if (mobileSearchInput.value.trim()) {
        mobileSearchResults.classList.remove('hidden');
        performSearch(mobileSearchInput.value, mobileSearchResults, null);
      } else {
        mobileSearchResults.classList.add('hidden');
        mobileSearchResults.innerHTML = '';
      }
    });

    mobileSearchInput.addEventListener('blur', () => {
      setTimeout(() => {
        mobileSearchResults.classList.add('hidden');
      }, 200);
    });
  }

  // --- Mobile Menu ---
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggleBtn && menu) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', String(!isExpanded));
      menu.classList.toggle('hidden');
    });
  }

  // --- Theme Toggle ---
  const themeToggle = document.getElementById('theme-toggle');
  const sunIcon = document.getElementById('theme-icon-sun');
  const moonIcon = document.getElementById('theme-icon-moon');

  function getTheme() { return localStorage.getItem('mi_theme') || 'system'; }

  function updateIcons() {
    if (!sunIcon || !moonIcon) return;
    const isDarkNow = document.documentElement.classList.contains('dark');
    if (isDarkNow) { sunIcon.classList.remove('hidden'); moonIcon.classList.add('hidden'); }
    else { sunIcon.classList.add('hidden'); moonIcon.classList.remove('hidden'); }
  }

  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isCurrentlyDark = document.documentElement.classList.contains('dark');
      const newTheme = isCurrentlyDark ? 'light' : 'dark';
      localStorage.setItem('mi_theme', newTheme);
      document.documentElement.classList.toggle('dark', newTheme === 'dark');
      updateIcons();
      window.dispatchEvent(new Event('themechange'));
    });
    updateIcons();
  }

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (getTheme() === 'system') {
      const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.classList.toggle('dark', isDark);
      updateIcons();
      window.dispatchEvent(new Event('themechange'));
    }
  });

  // Keyboard shortcut hint
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      const overlay = document.getElementById('search-overlay');
      if (overlay) {
        if (overlay.classList.contains('hidden')) {
          document.getElementById('search-toggle')?.click();
        }
      }
    }
  });
</script>
