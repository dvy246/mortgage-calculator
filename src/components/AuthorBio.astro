---
interface Props {
  authorKey: 'sarah' | 'marcus';
}

const { authorKey } = Astro.props;

const authors = {
  sarah: {
    name: "Sarah Jenkins, CFP®",
    title: "Chief Underwriting & Mortgage Analyst",
    bio: "Sarah Jenkins is a Certified Financial Planner with over 14 years of experience in residential mortgage underwriting and private wealth advisory. She previously managed mortgage originations and credit risk assessments at major retail financial institutions. Sarah is dedicated to helping consumers optimize their debt portfolios and purchase properties with long-term financial security.",
    specialties: ["First-Time Home Buyers", "PMI Removal Planning", "Conventional Underwriting"],
    avatar: `<svg class="h-10 w-10 text-brand-accent bg-brand-accent/10 rounded-full p-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`
  },
  marcus: {
    name: "Marcus Vance",
    title: "Senior Credit & Loan Policy Advisor",
    bio: "Marcus Vance is a residential financing expert with 12 years of experience specializing in credit policy audits, loan-level price adjustments (LLPAs), and regional property tax assessment patterns. Having worked as a mortgage compliance officer, Marcus reviews calculator models and underwriting guides to verify alignment with current GSE (Fannie Mae & Freddie Mac) and Federal Housing Administration standards.",
    specialties: ["FHA Lending Criteria", "Jumbo Loan Structures", "LLPA Optimization"],
    avatar: `<svg class="h-10 w-10 text-brand-accent bg-brand-accent/10 rounded-full p-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`
  }
};

const author = authors[authorKey];
---

<div class="rounded-xl border border-border-subtle bg-bg-card p-6 space-y-4">
  <div class="flex items-start gap-4">
    <div class="shrink-0">
      <Fragment set:html={author.avatar} />
    </div>
    <div class="space-y-1">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5">
        <h4 class="font-display text-sm font-bold text-text-main leading-tight">{author.name}</h4>
        <span class="inline-flex items-center rounded-full bg-brand-accent/10 px-2 py-0.5 text-4xs font-medium text-brand-accent border border-brand-accent/20">Verified Contributor</span>
      </div>
      <p class="text-3xs text-text-muted font-medium">{author.title} • Editorial Board</p>
    </div>
  </div>
  
  <p class="text-2xs text-text-muted leading-relaxed">
    {author.bio}
  </p>

  <div class="flex flex-wrap items-center gap-2 pt-2 border-t border-border-subtle/30">
    <span class="text-4xs uppercase tracking-wider text-text-muted/60 font-semibold">Focus Areas:</span>
    {author.specialties.map(spec => (
      <span class="text-4xs bg-bg-main border border-border-subtle px-2 py-0.5 rounded text-text-muted">{spec}</span>
    ))}
  </div>
</div>
