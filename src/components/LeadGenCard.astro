---
---
<div class="rounded-xl border border-border-subtle bg-bg-card p-6 space-y-6" id="rates-cta">
  <div class="flex items-center gap-3">
    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-500/10 text-blue-500">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="1" x2="12" y2="23" />
        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
      </svg>
    </div>
    <div>
      <h3 class="font-display text-sm font-semibold text-text-main">Custom Interest Rates</h3>
      <p class="text-xs text-text-muted mt-0.5">Compare live pre-approved offers based on your profile.</p>
    </div>
  </div>

  <form id="lead-gen-form" class="space-y-4 text-xs">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label for="lead-zip" class="block font-medium text-text-muted mb-1.5">Zip Code</label>
        <input 
          type="text" 
          id="lead-zip" 
          name="zip_code" 
          placeholder="e.g. 75001" 
          maxlength="5"
          pattern="[0-9]{5}"
          class="h-9 w-full rounded-md border border-border-input bg-bg-input px-3 text-text-main placeholder-text-muted/65 focus:border-border-focus focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
          required
        />
      </div>
      <div>
        <label for="lead-credit" class="block font-medium text-text-muted mb-1.5">Credit Score</label>
        <select 
          id="lead-credit" 
          name="credit_score" 
          class="h-9 w-full rounded-md border border-border-input bg-bg-input px-2.5 text-text-main focus:border-border-focus focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
          required
        >
          <option value="excellent">Excellent (740+)</option>
          <option value="good">Good (670-739)</option>
          <option value="fair">Fair (580-669)</option>
          <option value="poor">Poor (Below 580)</option>
        </select>
      </div>
    </div>

    <div>
      <label for="lead-purpose" class="block font-medium text-text-muted mb-1.5">Loan Purpose</label>
      <select 
        id="lead-purpose" 
        name="loan_purpose" 
        class="h-9 w-full rounded-md border border-border-input bg-bg-input px-2.5 text-text-main focus:border-border-focus focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
        required
      >
        <option value="purchase">Buy a Home</option>
        <option value="refinance">Refinance Existing Loan</option>
        <option value="equity">Cash Out Equity</option>
      </select>
    </div>

    <button 
      type="submit" 
      class="inline-flex h-9 w-full items-center justify-center rounded-md bg-brand-primary text-xs font-semibold text-bg-card hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent border border-border-subtle"
      id="lead-submit-btn"
    >
      Find Match Rates
    </button>
  </form>

  <div class="hidden text-center py-6 text-xs text-text-muted space-y-2" id="lead-success-msg" aria-live="polite">
    <svg class="mx-auto h-8 w-8 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <p class="font-semibold text-text-main">Quotes Request Sent</p>
    <p class="text-text-muted leading-normal">Connecting you with our partner lenders database... You will receive rate quotes shortly.</p>
  </div>
</div>

<script>
  const form = document.getElementById('lead-gen-form') as HTMLFormElement;
  const successMsg = document.getElementById('lead-success-msg');
  const submitBtn = document.getElementById('lead-submit-btn') as HTMLButtonElement;

  if (form && successMsg && submitBtn) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Vercel UI loading state
      submitBtn.disabled = true;
      submitBtn.textContent = "Connecting…";
      
      setTimeout(() => {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
      }, 1200);
    });
  }
</script>
