---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SVGCharts from '../components/Calculator/SVGCharts.astro';
import StressTest from '../components/Calculator/StressTest.astro';
import AmortizationTable from '../components/Calculator/AmortizationTable.astro';
import LeadGenCard from '../components/LeadGenCard.astro';
import Disclaimer from '../components/Calculator/Disclaimer.astro';
import MortgageGuide from '../components/Calculator/MortgageGuide.astro';
import PrintModal from '../components/Calculator/PrintModal.astro';
import MortgageReport from '../components/Calculator/MortgageReport.astro';
import FormulaDrawer from '../components/Calculator/FormulaDrawer.astro';
import AdSlot from '../components/AdSlot.astro';

const faqs = [
  {
    question: "When can I request PMI removal?",
    answer: "You can write to your servicer to request PMI cancellation once your balance reaches 80% of the original purchase price. Under the Homeowners Protection Act, it must terminate automatically when your balance drops to 78% LTV."
  },
  {
    question: "How does the loan term affect interest paid?",
    answer: "A 15-year fixed loan features a higher monthly payment than a 30-year fixed loan, but because the principal decreases twice as fast and often carries lower interest rates, you pay up to 60% less total interest over the life of the loan."
  },
  {
    question: "What is an escrow account?",
    answer: "An escrow account is a holding account managed by your mortgage servicer. They collect a portion of property taxes and homeowners insurance inside your monthly payment and pay those bills on your behalf when they renew."
  }
];
---

<Layout 
  title="Mortgage Payoff Calculator - Model Your Loan Repayment"
  description="Calculate your monthly payments, interest totals, and amortization schedule. Model PMI drop thresholds and rate shock variables."
  canonicalUrl="/mortgage-payoff-calculator"
>
  <Header activeSlug="payoff" />

  <!-- PDF Print Report Header -->
  <div id="print-header" class="border-b border-border-subtle pb-4 mb-6 hidden">
    <div class="flex justify-between items-end">
      <div>
        <h1 class="text-xl font-bold font-display text-text-main">Mortgage Intelligence Report</h1>
        <p class="text-2xs text-text-muted">Advisory Assessment: Standard Mortgage Payoff Timeline</p>
      </div>
      <div class="text-right text-text-muted text-2xs">
        <span>Generated: {new Date().toLocaleDateString()}</span>
      </div>
    </div>
  </div>

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 space-y-10 flex-grow">
    <!-- Header Section -->
    <div class="space-y-2">
      <h1 class="font-display text-2xl font-bold text-text-main sm:text-3xl">Mortgage Payoff Calculator</h1>
      <p class="text-xs text-text-muted">Model your loan amortization schedule, project lifetime interest costs, and analyze LTV milestones.</p>
    </div>

    <!-- 2-Column Dashboard Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- LEFT: Controls Pane -->
      <div class="lg:col-span-5 space-y-6">
        <div class="rounded-xl border border-border-subtle bg-bg-card p-4 sm:p-6 space-y-6">
          <h2 class="font-display text-sm font-semibold text-text-main border-b border-border-subtle pb-2">Mortgage Details</h2>
          
          <!-- Home Price -->
          <div class="space-y-2">
            <div class="flex justify-between text-xs">
              <span class="flex items-center">
                <label for="price-input" class="font-medium text-text-muted">Home Purchase Price</label>
                <span class="tooltip-container ml-1.5 cursor-help text-text-muted hover:text-text-main" tabindex="0">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                  <span class="tooltip-text">The total transaction value or contract price of the home you plan to purchase.</span>
                </span>
              </span>
              <span class="font-bold text-text-main font-tabular" id="price-display">$400,000</span>
            </div>
            <input 
              type="range" 
              id="price-slider" 
              min="100000" 
              max="1500000" 
              step="10000" 
              value="400000" 
              aria-label="Home Purchase Price Slider"
            />
            <div class="flex gap-2">
              <span class="text-text-muted/65 text-3xs">$100k</span>
              <input 
                type="number" 
                id="price-input" 
                value="400000" 
                class="h-7 w-full rounded border border-border-input bg-bg-input px-2 text-xs text-text-main font-tabular focus:border-border-focus focus:outline-none"
                aria-label="Home Purchase Price Input"
              />
              <span class="text-text-muted/65 text-3xs">$1.5M</span>
            </div>
          </div>

          <!-- Down Payment -->
          <div class="space-y-2">
            <div class="flex justify-between text-xs">
              <span class="flex items-center">
                <label for="down-input" class="font-medium text-text-muted">Down Payment</label>
                <span class="tooltip-container ml-1.5 cursor-help text-text-muted hover:text-text-main" tabindex="0">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                  <span class="tooltip-text">Your upfront closing cash. Down payments under 20% require private mortgage insurance (PMI).</span>
                </span>
              </span>
              <span class="font-bold text-text-main font-tabular" id="down-display">$80,000 (20%)</span>
            </div>
            <input 
              type="range" 
              id="down-slider" 
              min="0" 
              max="500000" 
              step="5000" 
              value="80000" 
              aria-label="Down Payment Slider"
            />
            <div class="flex gap-2">
              <span class="text-text-muted/65 text-3xs">$0</span>
              <input 
                type="number" 
                id="down-input" 
                value="80000" 
                class="h-7 w-full rounded border border-border-input bg-bg-input px-2 text-xs text-text-main font-tabular focus:border-border-focus focus:outline-none"
                aria-label="Down Payment Input"
              />
              <span class="text-text-muted/65 text-3xs">$500k</span>
            </div>
          </div>

          <!-- Rate & Term Group -->
          <div class="grid grid-cols-2 gap-4 text-xs">
            <div class="space-y-1.5">
              <span class="flex items-center">
                <label for="rate-input" class="font-medium text-text-muted">Interest Rate</label>
                <span class="tooltip-container ml-1.5 cursor-help text-text-muted hover:text-text-main" tabindex="0">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                  <span class="tooltip-text">Annual interest rate. Small adjustments (even 0.25%) yield massive lifetime principal changes.</span>
                </span>
              </span>
              <input 
                type="number" 
                id="rate-input" 
                value="6.50" 
                step="0.1" 
                min="0.1" 
                max="15"
                class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none"
              />
            </div>
            <div class="space-y-1.5">
              <span class="flex items-center">
                <label for="term-select" class="font-medium text-text-muted">Loan Term</label>
                <span class="tooltip-container ml-1.5 cursor-help text-text-muted hover:text-text-main" tabindex="0">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                  <span class="tooltip-text">Standard mortgage lengths. 30-year is the popular configuration, though 15-year saves substantial interest charges.</span>
                </span>
              </span>
              <select 
                id="term-select" 
                class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main focus:border-border-focus focus:outline-none"
              >
                <option value="30">30 Years, Fixed</option>
                <option value="20">20 Years, Fixed</option>
                <option value="15">15 Years, Fixed</option>
                <option value="10">10 Years, Fixed</option>
              </select>
            </div>
          </div>

          <!-- Advanced Toggle -->
          <details class="group text-xs">
            <summary class="flex justify-between items-center cursor-pointer text-text-muted font-semibold hover:text-text-main py-2">
              <span>Escrow & Associated Expenses</span>
              <svg class="h-4 w-4 transform group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="space-y-4 pt-3 border-t border-border-subtle mt-2">
              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                  <span class="flex items-center">
                    <label for="tax-input" class="font-medium text-text-muted">Property Tax Rate (%)</label>
                    <span class="tooltip-container ml-1.5 cursor-help text-text-muted hover:text-text-main" tabindex="0">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                      <span class="tooltip-text">Annual local property tax percentage. Standard national average is around 1.1%, though varies significantly by state.</span>
                    </span>
                  </span>
                  <input type="number" id="tax-input" value="1.1" step="0.05" class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none" />
                </div>
                <div class="space-y-1.5">
                  <span class="flex items-center">
                    <label for="ins-input" class="font-medium text-text-muted">Home Insurance (%)</label>
                    <span class="tooltip-container ml-1.5 cursor-help text-text-muted hover:text-text-main" tabindex="0">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                      <span class="tooltip-text">Annual homeowner's insurance premium percentage. Typically ranges from 0.3% to 0.8% of home value.</span>
                    </span>
                  </span>
                  <input type="number" id="ins-input" value="0.5" step="0.05" class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none" />
                </div>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                  <span class="flex items-center">
                    <label for="pmi-input" class="font-medium text-text-muted">PMI Rate (%)</label>
                    <span class="tooltip-container ml-1.5 cursor-help text-text-muted hover:text-text-main" tabindex="0">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                      <span class="tooltip-text">Private Mortgage Insurance annual rate. Charged if down payment is under 20%. Standard Conventional PMI ranges from 0.3% to 1.5%.</span>
                    </span>
                  </span>
                  <input type="number" id="pmi-input" value="0.75" step="0.05" class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none" />
                </div>
                <div class="space-y-1.5">
                  <span class="flex items-center">
                    <label for="hoa-input" class="font-medium text-text-muted">Monthly HOA ($)</label>
                    <span class="tooltip-container ml-1.5 cursor-help text-text-muted hover:text-text-main" tabindex="0">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                      <span class="tooltip-text">Monthly Homeowners Association fees. Excluded from P&I but factored into total carrying costs and DTI limits.</span>
                    </span>
                  </span>
                  <input type="number" id="hoa-input" value="0" step="10" class="h-8 w-full rounded border border-border-input bg-bg-input px-2 text-text-main font-tabular focus:border-border-focus focus:outline-none" />
                </div>
              </div>
            </div>
          </details>
        </div>

        <LeadGenCard />
      </div>
      
      <!-- RIGHT: Dashboard Outputs -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Summary Dashboard Card -->
        <div class="rounded-xl border border-border-subtle bg-bg-card p-4 sm:p-6 grid grid-cols-2 gap-6 relative">
          <div>
            <span class="text-text-muted text-xs font-semibold block">Monthly Total Payment</span>
            <span class="text-3xl font-extrabold text-text-main font-display font-tabular tracking-tight mt-1" id="out-monthly">$0</span>
            <span class="text-3xs text-text-muted block mt-1" id="out-pi-split">P&I portion: $0</span>
          </div>
          <div class="border-l border-border-subtle pl-6 flex justify-between items-start">
            <div>
              <span class="text-text-muted text-xs font-semibold block">Total Interest Paid</span>
              <span class="text-3xl font-extrabold text-blue-500 font-display font-tabular tracking-tight mt-1" id="out-total-interest">$0</span>
              <span class="text-3xs text-text-muted block mt-1" id="out-total-cost">Total loan cost: $0</span>
            </div>
            
            <button 
              class="absolute top-4 right-4 p-1.5 rounded-md border border-border-subtle bg-bg-main hover:bg-bg-card-hover text-text-muted hover:text-brand-accent transition-colors cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
              id="download-report-btn"
              title="Download PDF Planning Report"
              aria-label="Download PDF Planning Report"
            >
              <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Milestones Box -->
        <div class="rounded-xl border border-border-subtle bg-bg-card p-4 sm:p-6 space-y-4 font-tabular">
          <h3 class="font-display text-sm font-semibold text-text-main">Loan Milestones & PMI</h3>
          <div class="grid grid-cols-2 gap-4 text-xs">
            <div class="p-3 bg-bg-main rounded-lg border border-border-subtle">
              <span class="text-text-muted block">Initial Loan-to-Value (LTV)</span>
              <span class="font-bold text-text-main font-tabular block mt-1" id="milestone-ltv">80%</span>
            </div>
            <div class="p-3 bg-bg-main rounded-lg border border-border-subtle">
              <span class="text-text-muted block">PMI Cancellation Date</span>
              <span class="font-bold text-emerald-500 font-tabular block mt-1" id="milestone-pmi">No PMI Required</span>
            </div>
          </div>
        </div>
        
        <SVGCharts />
        
        <StressTest />
        <MortgageReport />

      </div>
    </div>

    <!-- Repayment Table -->
    <AmortizationTable />

    <FormulaDrawer type="payoff" />

    <!-- Ad Slot: Between formula drawer and guide section -->
    <AdSlot format="horizontal" slot="2004" class="my-4" />

    <!-- Contextual education handbook -->
    <MortgageGuide 
      title="Mortgage Payoff"
      subtitle="Analyzing your amortization timeline and LTV milestones"
      whatItDoes="This standard payoff engine models your monthly Principal and Interest payments and projects your lifetime cumulative interest costs. It simulates your loan balance month-by-month, mapping how your payments divide between paying down the mortgage debt and paying bank interest. It also incorporates escrow variables (property taxes, hazard insurance, and HOA dues) and private mortgage insurance (PMI) rates to project your true out-of-pocket costs and locate the exact month you will reach enough equity to cancel PMI."
      whenToUse="Use this calculator to analyze standard fixed-rate mortgages. It is especially useful when comparing loan options (such as choosing between a 30-year or a 15-year term) or analyzing how different down payment amounts alter your monthly P&I carrying costs, loan-to-value milestones, and lifetime interest burden."
      howItWorks="The calculator computes your fixed monthly Principal & Interest payment using the standard amortization annuity equation. It then runs a monthly loop over the loan term: multiplying the remaining principal balance by the monthly interest rate (annual APR divided by 12) to determine that month's interest cost. The rest of your payment is applied to reduce the principal balance. If the initial down payment is under 20% LTV, a monthly PMI cost is added to the housing payment. This PMI charge is automatically removed from subsequent payments once the monthly principal balance is amortized down to 80% LTV."
      mistakes="The most common mistake is failing to calculate the 'lifetime cost' of borrowing. Over a standard 30-year amortization schedule at a 6.5% interest rate, you will pay roughly 1.5 times the original loan principal in interest alone. Selecting a shorter term, like 15 years, or adding modest extra payments dramatically lowers this multiplier. Another pitfall is ignoring the impact of escrow expenses (taxes, insurance, HOA), which are not fixed and will rise over time, increasing your monthly housing bill even on a fixed-rate loan."
      faqs={faqs}
    />

    <!-- Disclaimer card -->
    <Disclaimer />
  </main>

  <!-- PDF Print Disclaimer -->
  <div id="print-disclaimer" class="hidden">
    <h4 class="font-bold mb-1">Mortgage Intelligence Report Disclaimer</h4>
    <p>
      This document constitutes an advisory summary compiled under user-input assumptions. Estimates are not guaranteed. Lenders will execute separate underwriting passes before issuing binding commitments. Consult certified financial planners.
    </p>
  </div>

  <PrintModal />
  <Footer />
</Layout>

<script>
  import { calculateMortgage } from '../utils/mortgage';

  // Grab inputs
  const priceSlider = document.getElementById('price-slider') as HTMLInputElement;
  const priceInput = document.getElementById('price-input') as HTMLInputElement;
  const priceDisplay = document.getElementById('price-display');

  const downSlider = document.getElementById('down-slider') as HTMLInputElement;
  const downInput = document.getElementById('down-input') as HTMLInputElement;
  const downDisplay = document.getElementById('down-display');

  const rateInput = document.getElementById('rate-input') as HTMLInputElement;
  const termSelect = document.getElementById('term-select') as HTMLSelectElement;

  const taxInput = document.getElementById('tax-input') as HTMLInputElement;
  const insInput = document.getElementById('ins-input') as HTMLInputElement;
  const pmiInput = document.getElementById('pmi-input') as HTMLInputElement;
  const hoaInput = document.getElementById('hoa-input') as HTMLInputElement;

  function syncInputs(slider: HTMLInputElement, input: HTMLInputElement, display: HTMLElement | null, isPrice = true) {
    const update = () => {
      input.value = slider.value;
      updateDisplay();
      recalculate();
    };
    slider.addEventListener('input', update);
    input.addEventListener('input', () => {
      let val = parseFloat(input.value) || 0;
      val = Math.min(parseFloat(slider.max), Math.max(parseFloat(slider.min), val));
      slider.value = String(val);
      updateDisplay();
      recalculate();
    });

    function updateDisplay() {
      if (!display) return;
      if (isPrice) {
        display.textContent = `$${parseInt(slider.value).toLocaleString('en-US')}`;
      } else {
        const price = parseFloat(priceSlider.value) || 1;
        const down = parseFloat(slider.value) || 0;
        const percent = Math.round((down / price) * 100);
        display.textContent = `$${down.toLocaleString('en-US')} (${percent}%)`;
      }
    }
  }

  syncInputs(priceSlider, priceInput, priceDisplay, true);
  syncInputs(downSlider, downInput, downDisplay, false);

  // Re-sync down payment slider max value when price changes
  priceSlider.addEventListener('input', () => {
    const maxDown = Math.floor(parseFloat(priceSlider.value) * 0.8); // Cap down payment slider at 80%
    downSlider.max = String(maxDown);
    if (parseFloat(downSlider.value) > maxDown) {
      downSlider.value = String(maxDown);
      downInput.value = String(maxDown);
    }
    downSlider.dispatchEvent(new Event('input'));
  });

  priceInput.addEventListener('input', () => {
    const maxDown = Math.floor(parseFloat(priceInput.value) * 0.8);
    downSlider.max = String(maxDown);
    if (parseFloat(downSlider.value) > maxDown) {
      downSlider.value = String(maxDown);
      downInput.value = String(maxDown);
    }
    downSlider.dispatchEvent(new Event('input'));
  });

  [rateInput, termSelect, taxInput, insInput, pmiInput, hoaInput].forEach(ctrl => {
    ctrl.addEventListener('input', recalculate);
  });

  function recalculate() {
    const homePrice = parseFloat(priceInput.value) || 0;
    const downPayment = parseFloat(downInput.value) || 0;
    const interestRate = parseFloat(rateInput.value) || 0;
    const loanTermYears = parseInt(termSelect.value) || 30;

    const propertyTaxRate = parseFloat(taxInput.value) || 0;
    const insuranceRate = parseFloat(insInput.value) || 0;
    const pmiRate = parseFloat(pmiInput.value) || 0;
    const hoaFee = parseFloat(hoaInput.value) || 0;

    const result = calculateMortgage({
      homePrice,
      downPayment,
      interestRate,
      loanTermYears,
      propertyTaxRate,
      insuranceRate,
      pmiRate,
      hoaFee,
      extraMonthly: 0,
      extraAnnual: 0,
      extraOneTime: []
    });

    const originalPrincipal = Math.max(0, homePrice - downPayment);
    const ltv = homePrice > 0 ? (originalPrincipal / homePrice) * 100 : 0;

    // Update displays
    const outMonthly = document.getElementById('out-monthly');
    const outPISplit = document.getElementById('out-pi-split');
    if (outMonthly) outMonthly.textContent = `$${Math.round(result.totalMonthlyPayment).toLocaleString('en-US')}`;
    if (outPISplit) outPISplit.textContent = `P&I portion: $${Math.round(result.monthlyPrincipalAndInterest).toLocaleString('en-US')}/mo`;

    const outInterest = document.getElementById('out-total-interest');
    const outTotalCost = document.getElementById('out-total-cost');
    if (outInterest) outInterest.textContent = `$${Math.round(result.totalInterestPaid).toLocaleString('en-US')}`;
    if (outTotalCost) outTotalCost.textContent = `Total loan cost: $${Math.round(result.totalPaymentsSum).toLocaleString('en-US')}`;

    // Update milestones
    const ltvEl = document.getElementById('milestone-ltv');
    const pmiEl = document.getElementById('milestone-pmi');
    if (ltvEl) ltvEl.textContent = `${ltv.toFixed(1)}%`;
    if (pmiEl) {
      if (ltv <= 80) {
        pmiEl.textContent = "No PMI Required (Down Payment ≥ 20%)";
        pmiEl.className = "font-bold text-emerald-400 block mt-1";
      } else {
        if (result.pmiCancellationMonth > 0) {
          const yrs = (result.pmiCancellationMonth / 12).toFixed(1);
          pmiEl.textContent = `Drops at Month ${result.pmiCancellationMonth} (~${yrs} Years)`;
          pmiEl.className = "font-bold text-amber-400 block mt-1";
        } else {
          pmiEl.textContent = "Applies for Life of Loan";
          pmiEl.className = "font-bold text-rose-400 block mt-1";
        }
      }
    }

    // Donut and chart updates
    if (window.drawDonutChart) {
      window.drawDonutChart(
        result.monthlyPrincipalAndInterest,
        result.monthlyPropertyTax,
        result.monthlyInsurance,
        result.monthlyPMI,
        result.monthlyHOA
      );
    }

    if (window.drawAmortizationChart) {
      window.drawAmortizationChart(result.amortizationSchedule);
    }

    if ((window as any).generateMortgageReport) {
      (window as any).generateMortgageReport({
        homePrice,
        downPayment,
        interestRate,
        termYears: loanTermYears,
        monthlyPayment: result.totalMonthlyPayment,
        monthlyPI: result.monthlyPrincipalAndInterest,
        income: 0, // Not gathered
        debts: 0,
        pmi: result.monthlyPMI,
        hoa: result.monthlyHOA
      });
    }

    if ((window as any).updateChartInsights) {
      (window as any).updateChartInsights([
        {
          label: "Monthly Payment",
          value: `$${Math.round(result.totalMonthlyPayment).toLocaleString('en-US')}/mo`,
          badge: `P&I portion: $${Math.round(result.monthlyPrincipalAndInterest).toLocaleString('en-US')}`,
          badgeColor: "blue"
        },
        {
          label: "Interest Liability",
          value: `$${Math.round(result.totalInterestPaid).toLocaleString('en-US')}`,
          badge: `Total principal: $${Math.round(originalPrincipal).toLocaleString('en-US')}`,
          badgeColor: "amber"
        },
        {
          label: "Amortization Term",
          value: `${loanTermYears} Years`,
          badge: `${loanTermYears * 12} monthly cycles`,
          badgeColor: "blue"
        },
        {
          label: "PMI Termination",
          value: ltv <= 80 ? "No PMI" : (result.pmiCancellationMonth > 0 ? `Month ${result.pmiCancellationMonth}` : "Life of Loan"),
          badge: ltv <= 80 ? "Down payment ≥ 20%" : (result.pmiCancellationMonth > 0 ? "Reaches 80% LTV" : "PMI active"),
          badgeColor: ltv <= 80 ? "emerald" : (result.pmiCancellationMonth > 0 ? "amber" : "rose")
        }
      ]);
    }

    if (window.renderAmortizationTable) {
      window.renderAmortizationTable(result.amortizationSchedule);
    }

    if (window.updateStressTest) {
      window.updateStressTest(originalPrincipal, interestRate, loanTermYears, result.monthlyPropertyTax + result.monthlyInsurance + result.monthlyPMI + result.monthlyHOA);
    }

    // Register data for comparative save
    if (window.registerCurrentRunData) {
      window.registerCurrentRunData({
        homePrice,
        downPayment,
        interestRate,
        termYears: loanTermYears,
        monthlyPayment: result.totalMonthlyPayment,
        totalInterest: result.totalInterestPaid
      });
    }
  }

  // Bind PDF Download report trigger
  const printBtn = document.getElementById('download-report-btn');
  if (printBtn) {
    printBtn.addEventListener('click', () => {
      if ((window as any).openPrintModal) {
        (window as any).openPrintModal();
      } else {
        window.print();
      }
    });
  }

  recalculate();
</script>
