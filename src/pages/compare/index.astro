---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { comparisons } from '../../data/comparisons';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Mortgage Comparison Tools",
  "description": "Side-by-side comparison of different mortgage types, terms, and strategies to help you make informed home financing decisions.",
  "mainEntity": comparisons.map(c => ({
    "@type": "Article",
    "headline": c.title,
    "description": c.description,
    "url": `https://mortgagesintel.com/compare/${c.slug}`
  }))
};
---

<Layout
  title="Mortgage Comparison Tools - Side by Side Analysis"
  description="Compare 15-year vs 30-year mortgages, FHA vs conventional loans, ARM vs fixed rates, buying points, and extra payment strategies with our interactive comparison workspace."
  canonicalUrl="/compare"
  schemaMarkup={JSON.stringify(schema)}
>
  <Header activeSlug="compare" />

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 space-y-10 flex-grow">
    <div class="space-y-2">
      <h1 class="font-display text-2xl font-bold text-text-main sm:text-3xl">Mortgage Comparison Tools</h1>
      <p class="text-xs text-text-muted max-w-3xl">
        Side-by-side comparison of different mortgage types, terms, and strategies. Each interactive tool lets you adjust parameters and see real-time cost differences.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {comparisons.map(c => (
        <a
          href={`/compare/${c.slug}`}
          class="group rounded-xl border border-border-subtle bg-bg-card p-6 flex flex-col hover:border-border-focus hover:bg-bg-card-hover transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
        >
          <div class="space-y-3 flex-1">
            <h2 class="font-display text-base font-semibold text-text-main group-hover:text-brand-accent transition-colors">
              {c.title}
            </h2>
            <p class="text-xs text-text-muted leading-relaxed">{c.description}</p>
          </div>
          <div class="mt-4 flex flex-wrap gap-2">
            {c.scenarios.map(s => (
              <span class="inline-flex items-center rounded-full bg-blue-500/10 px-2.5 py-0.5 text-4xs font-medium text-blue-500 border border-blue-500/20">
                {s.name}
              </span>
            ))}
          </div>
          <div class="mt-4 flex items-center gap-1.5 text-xs font-semibold text-brand-accent group-hover:text-brand-accent-hover">
            <span>Compare Now</span>
            <svg class="h-3.5 w-3.5 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </div>
        </a>
      ))}
    </div>

    <!-- SEO Content Section -->
    <section class="border-t border-border-subtle pt-8 space-y-4 text-xs sm:text-sm text-text-muted leading-relaxed max-w-4xl">
      <h2 class="font-display text-lg font-bold text-text-main">Why Use a Mortgage Comparison Tool?</h2>
      <p>
        Choosing the right mortgage requires understanding how different terms, rates, and loan types affect your monthly payment and long-term costs. Instead of running calculations on multiple websites or browser tabs, our interactive comparison workspace lets you evaluate options side by side on a single screen.
      </p>
      <p>
        Each comparison tool comes pre-loaded with realistic scenarios based on current market conditions. You can adjust any variable — home price, down payment, interest rate, or term length — and see the impact across all scenarios instantly. The workspace automatically highlights the best value in each category, making it easy to identify the most cost-effective option for your situation.
      </p>
      <p>
        All calculations use the standard mortgage amortization formula and include property taxes, homeowners insurance, and PMI where applicable. Results are for educational purposes and should be verified with a licensed mortgage professional before making financial decisions.
      </p>

      <h3 class="font-display text-sm font-bold text-text-main pt-4">Available Comparisons</h3>
      <ul class="list-disc pl-5 space-y-1">
        {comparisons.map(c => (
          <li><a href={`/compare/${c.slug}`} class="text-brand-accent hover:underline">{c.title}</a></li>
        ))}
      </ul>
    </section>
  </main>

  <Footer />
</Layout>
