---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ScenarioComparer from '../../components/Calculator/ScenarioComparer.astro';
import MiniMortgageForm from '../../components/Calculator/MiniMortgageForm.astro';
import MortgageGuide from '../../components/Calculator/MortgageGuide.astro';
import Disclaimer from '../../components/Calculator/Disclaimer.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getComparisonBySlug, comparisonSlugs } from '../../data/comparisons';
import { calculateMortgage } from '../../utils/mortgage';
import type { ComparisonScenarioInputs } from '../../data/comparisons';

export async function getStaticPaths() {
  return comparisonSlugs.map(slug => ({
    params: { slug },
    props: { slug }
  }));
}

const { slug } = Astro.props;
const config = getComparisonBySlug(slug);

if (!config) {
  return Astro.redirect('/404');
}

function computeScenarioOutputs(inputs: ComparisonScenarioInputs) {
  const result = calculateMortgage({
    homePrice: inputs.homePrice,
    downPayment: inputs.downPayment,
    interestRate: inputs.interestRate,
    loanTermYears: inputs.loanTermYears,
    propertyTaxRate: inputs.propertyTaxRate,
    insuranceRate: inputs.insuranceRate,
    pmiRate: inputs.pmiRate,
    hoaFee: inputs.hoaFee,
    extraMonthly: inputs.extraMonthly,
    extraAnnual: inputs.extraAnnual,
    extraOneTime: []
  });
  return {
    monthlyPayment: result.totalMonthlyPayment,
    totalInterest: result.totalInterestPaid,
    totalCost: result.totalPaymentsSum,
    payoffYears: result.payoffTermMonths / 12,
    homePrice: inputs.homePrice,
    downPayment: inputs.downPayment,
    interestRate: inputs.interestRate,
    termYears: inputs.loanTermYears,
    monthlyPI: result.monthlyPrincipalAndInterest,
    monthlyTax: result.monthlyPropertyTax,
    monthlyInsurance: result.monthlyInsurance,
    monthlyPMI: result.monthlyPMI,
    monthlyHOA: result.monthlyHOA,
    pmiCancellationMonth: result.pmiCancellationMonth > 0 ? result.pmiCancellationMonth : undefined
  };
}

const scenarioObjects = config.scenarios.map((s, i) => {
  const outputs = computeScenarioOutputs(s);
  return {
    id: `comparison-${i}-${s.name.toLowerCase().replace(/\s+/g, '-')}`,
    name: s.name,
    type: 'mortgage' as const,
    inputs: { ...s },
    outputs,
    createdAt: Date.now() - (config.scenarios.length - i) * 1000
  };
});

const comparisonDataJson = JSON.stringify(scenarioObjects);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": config.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const tableSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": config.title,
  "description": config.description,
  "variableMeasured": config.scenarios.map((s, i) => ({
    "@type": "PropertyValue",
    "name": `${s.name} - Monthly Payment`,
    "value": computeScenarioOutputs(s).monthlyPayment
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mortgagesintel.com/" },
    { "@type": "ListItem", "position": 2, "name": "Comparisons", "item": "https://mortgagesintel.com/compare/" },
    { "@type": "ListItem", "position": 3, "name": config.title }
  ]
};

const combinedSchema = JSON.stringify([faqSchema, tableSchema, breadcrumbSchema]);
---

<Layout
  title={config.title}
  description={config.description}
  canonicalUrl={`/compare/${config.slug}`}
  schemaMarkup={combinedSchema}
>
  <Header activeSlug="compare" />

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 space-y-10 flex-grow">
    <!-- Header -->
    <div class="space-y-2">
      <nav class="text-3xs text-text-muted mb-4" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-brand-accent transition-colors">Home</a></li>
          <li><span class="mx-1">/</span></li>
          <li><a href="/compare" class="hover:text-brand-accent transition-colors">Comparisons</a></li>
          <li><span class="mx-1">/</span></li>
          <li class="text-text-main font-semibold truncate max-w-[200px] sm:max-w-[400px]" aria-current="page">{config.title}</li>
        </ol>
      </nav>
      <h1 class="font-display text-2xl font-bold text-text-main sm:text-3xl">{config.title}</h1>
      <p class="text-xs text-text-muted max-w-3xl">{config.description}</p>
    </div>

    <!-- Interactive Comparison Workspace -->
    <ScenarioComparer
      type="all"
      title="Interactive Comparison"
      subtitle="Adjust parameters below to see how changes affect each scenario. The best value in each category is highlighted in green."
      showShareButton={true}
      comparisonPageScenarios={comparisonDataJson}
    />

    <!-- Custom Scenario Builder -->
    <MiniMortgageForm
      defaultHomePrice={config.scenarios[0].homePrice}
      defaultDownPayment={config.scenarios[0].downPayment}
      defaultRate={config.scenarios[0].interestRate}
      defaultTerm={config.scenarios[0].loanTermYears}
      defaultTaxRate={config.scenarios[0].propertyTaxRate}
      defaultInsuranceRate={config.scenarios[0].insuranceRate}
      scenarioPrefix="Custom"
    />

    <!-- Ad Slot -->
    <AdSlot format="horizontal" slot="2003" class="my-4" />

    <!-- Educational Guide -->
    <MortgageGuide
      title={config.guideTitle}
      subtitle={config.guideSubtitle}
      whatItDoes={config.whatItDoes}
      whenToUse={config.whenToUse}
      howItWorks={config.howItWorks}
      mistakes={config.mistakes}
      faqs={config.faqs}
    />

    <!-- Related Calculators -->
    <div class="rounded-xl border border-border-subtle bg-bg-card p-5 space-y-4">
      <h2 class="font-display text-sm font-semibold text-text-main">Explore Related Calculators</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 text-xs">
        <a href="/mortgage-payoff-calculator" class="p-3 rounded-lg border border-border-subtle bg-bg-main hover:border-border-focus hover:bg-bg-card-hover transition-colors flex items-center gap-2">
          <svg class="h-4 w-4 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span class="text-text-main font-semibold">Mortgage Payoff Calculator</span>
        </a>
        <a href="/refinance-calculator" class="p-3 rounded-lg border border-border-subtle bg-bg-main hover:border-border-focus hover:bg-bg-card-hover transition-colors flex items-center gap-2">
          <svg class="h-4 w-4 text-pink-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
          <span class="text-text-main font-semibold">Refinance Calculator</span>
        </a>
        <a href="/extra-payment-calculator" class="p-3 rounded-lg border border-border-subtle bg-bg-main hover:border-border-focus hover:bg-bg-card-hover transition-colors flex items-center gap-2">
          <svg class="h-4 w-4 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
          <span class="text-text-main font-semibold">Extra Payment Calculator</span>
        </a>
      </div>
    </div>

    <Disclaimer />
  </main>

  <Footer />
</Layout>
