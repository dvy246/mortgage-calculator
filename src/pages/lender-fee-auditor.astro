---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// YMYL Disclaimers and FAQs for SEO and User Safety
const faqs = [
  {
    question: "What is a mortgage 'junk fee'?",
    answer: "A junk fee is an inflated or unnecessary administrative fee charged by a lender at closing. These often include document preparation fees, application fees, courier fees, or separate processing and underwriting charges. While underwriters do perform valuable risk assessment work, charging high fees for both processing and underwriting can represent double-charging for administrative tasks. Many of these fees can be negotiated, matched, or waived entirely."
  },
  {
    question: "Which closing costs are legally locked under TRID rules?",
    answer: "Under the CFPB's TRID (TILA-RESPA Integrated Disclosure) rules, lender origination charges (Section A) and transfer taxes are subject to a '0% tolerance'. This means once a lender issues an official Loan Estimate, they cannot increase these fees at closing unless there is a valid 'changed circumstance' (such as a change in loan program or appraisal issues)."
  },
  {
    question: "What is the difference between 0% tolerance and 10% tolerance fees?",
    answer: "Lender origination charges and transfer taxes have a 0% tolerance and cannot increase at closing. Third-party services required by the lender where you cannot shop for the provider (such as lender-selected title services, appraisals, or credit reports) have a cumulative 10% tolerance, meaning their total cost cannot rise by more than 10% in aggregate. Prepaids, escrows, and services you shop for independently have no tolerance limit."
  },
  {
    question: "How do I shop for independent Title Insurance and Settlement Escrow?",
    answer: "Section C of your Loan Estimate lists 'Services You Can Shop For'. You do not have to use the title insurance company or closing escrow agent recommended by your lender. By requesting quotes from independent title companies, you can compare premiums and administrative fees, which can vary by hundreds or even thousands of dollars. Simply notify your loan officer of your selected provider before closing."
  },
  {
    question: "Are underwriting fees and processing fees both negotiable?",
    answer: "Yes. While underwriters assess loan risk and processors handle paperwork, charging high fees for both is common but highly negotiable. You can ask the lender to consolidate them into a single fee, reduce them to match national averages (typically around $950 for underwriting and $750 for processing), or waive them entirely in exchange for locking your interest rate."
  },
  {
    question: "Can a lender charge an application fee or commitment fee?",
    answer: "Many competitive lenders do not charge upfront application or commitment fees. If your Loan Estimate lists an application fee (often $200-$500), this is a prime candidate for negotiation. Ask the lender to waive it or match a competitor's loan estimate that does not charge one."
  },
  {
    question: "How do loan discount points differ from lender origination fees?",
    answer: "Discount points are optional fees paid directly to the lender at closing to buy down your interest rate (typically 1 point equals 1% of the loan amount and lowers your rate by 0.25%). Origination fees, on the other hand, are administrative charges for processing the loan and do not lower your interest rate. Make sure that any discount points listed are explicitly lowering your rate compared to a zero-point estimate."
  },
  {
    question: "What should I do if a fee on my Closing Disclosure is higher than the Loan Estimate?",
    answer: "Compare Section A, B, and C of both documents. If a 0% tolerance fee has increased, or if 10% tolerance fees have increased by more than 10% in total, ask your loan officer for a detailed explanation. If the increase is not due to a documented changed circumstance, the lender is legally required to issue a credit at closing to correct the overage."
  },
  {
    question: "How does location affect average mortgage closing costs?",
    answer: "Closing costs are highly state-dependent. Government-imposed transfer taxes and recording fees are set by state and county governments and cannot be negotiated. Title insurance rates are highly regulated in some states (like Texas and Florida, where rates are set by the state insurance commissioner) but are highly competitive and shoppable in others (like California and New York)."
  },
  {
    question: "Is this fee auditor report a formal legal or financial evaluation?",
    answer: "No. This fee auditor is an educational tool designed to help you compare your Loan Estimate line items with state-level and national averages and identify potential areas of savings. It does not provide legal representation, formal underwriting, or legal or financial advice. Always verify fees with your licensed mortgage professional or real estate attorney."
  }
];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Lender Loan Estimate Auditor & Fee Negotiator",
      "url": "https://mortgagesintel.com/lender-fee-auditor",
      "description": "An interactive tool to audit mortgage Loan Estimate page 2 fees, uncover hidden junk fees, compare costs against regional benchmarks, and draft custom email negotiation scripts.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }
  ]
};
---

<Layout 
  title="Lender Loan Estimate Auditor & Fee Negotiator"
  description="Audit your mortgage Loan Estimate (LE) Page 2 fees. Uncover hidden lender junk fees, compare closing costs to regional benchmarks, and generate a customized fee negotiation script."
  canonicalUrl="/lender-fee-auditor"
  schemaMarkup={JSON.stringify(schema)}
>
  <Header activeSlug="lender-fee-auditor" />

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 space-y-10 flex-grow">
    <!-- Header Section -->
    <div class="space-y-4">
      <h1 class="font-display text-2xl font-bold text-text-main sm:text-3xl lg:text-4xl tracking-tight">
        Lender Loan Estimate Auditor <span class="text-brand-accent">& Fee Negotiator</span>
      </h1>
      <p class="text-xs sm:text-sm text-text-muted max-w-3xl leading-relaxed">
        Lenders frequently bundle unnecessary administrative fees into your mortgage closing costs. This tool compares your Loan Estimate (LE) line items against state-level averages, calculates legal CFPB tolerances, and writes your negotiation emails.
      </p>
      <p class="text-3xs text-text-muted">Reviewed by <strong>Marcus Vance</strong>, Senior Credit &amp; Loan Policy Advisor &mdash; Last updated <time datetime="2026-07-18">July 2026</time></p>
    </div>

    <!-- AdSense Notice and Safety Banner -->
    <div class="rounded-xl border border-warning/30 bg-warning/5 p-4 text-xs text-text-muted space-y-2 leading-relaxed">
      <div class="flex items-center gap-2 font-bold text-warning">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span>Consumer Advisory & Disclaimer</span>
      </div>
      <p>
        <strong>Disclaimer:</strong> This application is for educational and illustrative purposes only. All benchmark estimates are based on industry surveys and average cost disclosures. This tool does not constitute legal representation, formal lending approval, or official financial advice. We encourage users to verify all fees with their licensed mortgage loan officer or independent real estate attorney. All calculations are executed securely within your browser; no personal financial documents are uploaded or stored.
      </p>
    </div>

    <!-- Main Dashboard Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- LEFT: Inputs (LE replica form) (7 Cols) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Regional Settings Card -->
        <div class="rounded-xl border border-border-subtle bg-bg-card p-5 space-y-4 shadow-sm">
          <h2 class="font-display text-sm font-semibold text-text-main flex items-center gap-2">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-brand-primary text-bg-main text-3xs font-bold">1</span>
            Select Your Location & Loan Info
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="state-select" class="text-xs font-semibold text-text-muted">US State (for fee benchmarks)</label>
              <select 
                id="state-select" 
                class="h-9 w-full rounded-md border border-border-input bg-bg-input px-3 text-xs text-text-main font-semibold focus:border-border-focus focus:outline-none cursor-pointer"
              >
                <option value="CA">California</option>
                <option value="TX">Texas</option>
                <option value="NY">New York</option>
                <option value="FL">Florida</option>
                <option value="IL">Illinois</option>
                <option value="PA">Pennsylvania</option>
                <option value="OH">Ohio</option>
                <option value="GA">Georgia</option>
                <option value="NC">North Carolina</option>
                <option value="MI">Michigan</option>
                <option value="OTHER" selected>Other / National Average</option>
              </select>
            </div>
            <div class="space-y-1.5">
              <label for="loan-amount-input" class="text-xs font-semibold text-text-muted">Expected Loan Amount</label>
              <div class="relative">
                <span class="absolute left-3 top-2 text-xs font-bold text-text-muted">$</span>
                <input 
                  type="number" 
                  id="loan-amount-input" 
                  value="350000" 
                  step="5000"
                  class="h-9 w-full rounded-md border border-border-input bg-bg-input pl-6 pr-3 text-xs text-text-main font-bold font-tabular focus:border-border-focus focus:outline-none"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Section A: Origination Charges -->
        <div class="rounded-xl border border-border-subtle bg-bg-card p-5 space-y-4 shadow-sm">
          <div class="flex justify-between items-center border-b border-border-subtle pb-3">
            <h2 class="font-display text-sm font-semibold text-text-main flex items-center gap-2">
              <span class="flex h-5 w-5 items-center justify-center rounded-full bg-brand-primary text-bg-main text-3xs font-bold">2</span>
              A. Origination Charges (0% Tolerance)
            </h2>
            <span class="px-2 py-0.5 rounded text-4xs font-bold bg-rose-500/10 text-rose-500 border border-rose-500/20">Lender Fees</span>
          </div>

          <p class="text-3xs text-text-muted leading-relaxed">
            These are administrative fees charged by the lender to set up the loan. They are fully locked once the final Loan Estimate is issued. Look for double charges (e.g. charging both processing AND underwriting).
          </p>

          <div class="space-y-4">
            <!-- Underwriting Fee -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-border-subtle pb-3">
              <div class="space-y-0.5">
                <label for="underwriting-input" class="text-xs font-bold text-text-main block">Underwriting Fee</label>
                <span class="text-3xs text-text-muted block">National Benchmark: <strong class="text-text-main font-tabular">$950</strong></span>
              </div>
              <div class="flex items-center gap-3">
                <div class="relative">
                  <span class="absolute left-2.5 top-1.5 text-xs text-text-muted">$</span>
                  <input type="number" id="underwriting-input" value="1250" class="fee-input h-8 w-28 rounded border border-border-input bg-bg-input pl-5 pr-2 text-xs font-tabular text-text-main focus:outline-none" />
                </div>
                <span class="audit-badge px-2 py-0.5 rounded text-4xs font-bold hidden"></span>
              </div>
            </div>

            <!-- Processing Fee -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-border-subtle pb-3">
              <div class="space-y-0.5">
                <label for="processing-input" class="text-xs font-bold text-text-main block">Processing Fee</label>
                <span class="text-3xs text-text-muted block">National Benchmark: <strong class="text-text-main font-tabular">$750</strong></span>
              </div>
              <div class="flex items-center gap-3">
                <div class="relative">
                  <span class="absolute left-2.5 top-1.5 text-xs text-text-muted">$</span>
                  <input type="number" id="processing-input" value="950" class="fee-input h-8 w-28 rounded border border-border-input bg-bg-input pl-5 pr-2 text-xs font-tabular text-text-main focus:outline-none" />
                </div>
                <span class="audit-badge px-2 py-0.5 rounded text-4xs font-bold hidden"></span>
              </div>
            </div>

            <!-- Application/Commitment Fee -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-border-subtle pb-3">
              <div class="space-y-0.5">
                <label for="application-input" class="text-xs font-bold text-text-main block">Application or Commitment Fee</label>
                <span class="text-3xs text-text-muted block">National Benchmark: <strong class="text-text-main font-tabular">$0</strong> (Often Waived)</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="relative">
                  <span class="absolute left-2.5 top-1.5 text-xs text-text-muted">$</span>
                  <input type="number" id="application-input" value="350" class="fee-input h-8 w-28 rounded border border-border-input bg-bg-input pl-5 pr-2 text-xs font-tabular text-text-main focus:outline-none" />
                </div>
                <span class="audit-badge px-2 py-0.5 rounded text-4xs font-bold hidden"></span>
              </div>
            </div>
            
            <!-- Loan Discount Points -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
              <div class="space-y-0.5">
                <label for="points-input" class="text-xs font-bold text-text-main block">Discount Points Paid (to buy down interest rate)</label>
                <span class="text-3xs text-text-muted block">Ensure your interest rate is lower if discount points are charged.</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="relative">
                  <span class="absolute left-2.5 top-1.5 text-xs text-text-muted">$</span>
                  <input type="number" id="points-input" value="0" class="fee-input h-8 w-28 rounded border border-border-input bg-bg-input pl-5 pr-2 text-xs font-tabular text-text-main focus:outline-none" />
                </div>
                <span class="audit-badge px-2 py-0.5 rounded text-4xs font-bold hidden"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Section B: Services You Cannot Shop For (10% Tolerance limit) -->
        <div class="rounded-xl border border-border-subtle bg-bg-card p-5 space-y-4 shadow-sm">
          <div class="flex justify-between items-center border-b border-border-subtle pb-3">
            <h2 class="font-display text-sm font-semibold text-text-main flex items-center gap-2">
              <span class="flex h-5 w-5 items-center justify-center rounded-full bg-brand-primary text-bg-main text-3xs font-bold">3</span>
              B. Services You Cannot Shop For (10% Tolerance)
            </h2>
            <span class="px-2 py-0.5 rounded text-4xs font-bold bg-amber-500/10 text-amber-500 border border-amber-500/20">Lender-Selected</span>
          </div>

          <p class="text-3xs text-text-muted leading-relaxed">
            These are services required by the lender that you must use their selected provider for. These fees are legally protected under a cumulative 10% limit—the actual cost at closing cannot exceed the Loan Estimate by more than 10%.
          </p>

          <div class="space-y-4">
            <!-- Appraisal Fee -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-border-subtle pb-3">
              <div class="space-y-0.5">
                <label for="appraisal-input" class="text-xs font-bold text-text-main block">Home Appraisal Fee</label>
                <span class="text-3xs text-text-muted block">National Benchmark: <strong class="text-text-main font-tabular">$550</strong></span>
              </div>
              <div class="flex items-center gap-3">
                <div class="relative">
                  <span class="absolute left-2.5 top-1.5 text-xs text-text-muted">$</span>
                  <input type="number" id="appraisal-input" value="650" class="fee-input h-8 w-28 rounded border border-border-input bg-bg-input pl-5 pr-2 text-xs font-tabular text-text-main focus:outline-none" />
                </div>
                <span class="audit-badge px-2 py-0.5 rounded text-4xs font-bold hidden"></span>
              </div>
            </div>

            <!-- Credit Report Fee -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
              <div class="space-y-0.5">
                <label for="credit-input" class="text-xs font-bold text-text-main block">Credit Report Fee</label>
                <span class="text-3xs text-text-muted block">National Benchmark: <strong class="text-text-main font-tabular">$35 - $75</strong> (Tri-Merge Report)</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="relative">
                  <span class="absolute left-2.5 top-1.5 text-xs text-text-muted">$</span>
                  <input type="number" id="credit-input" value="125" class="fee-input h-8 w-28 rounded border border-border-input bg-bg-input pl-5 pr-2 text-xs font-tabular text-text-main focus:outline-none" />
                </div>
                <span class="audit-badge px-2 py-0.5 rounded text-4xs font-bold hidden"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Section C: Services You Can Shop For (No Limit / Negotiable) -->
        <div class="rounded-xl border border-border-subtle bg-bg-card p-5 space-y-4 shadow-sm">
          <div class="flex justify-between items-center border-b border-border-subtle pb-3">
            <h2 class="font-display text-sm font-semibold text-text-main flex items-center gap-2">
              <span class="flex h-5 w-5 items-center justify-center rounded-full bg-brand-primary text-bg-main text-3xs font-bold">4</span>
              C. Services You Can Shop For (Negotiable)
            </h2>
            <span class="px-2 py-0.5 rounded text-4xs font-bold bg-emerald-500/10 text-emerald-500 border border-emerald-500/20">Shoppable</span>
          </div>

          <p class="text-3xs text-text-muted leading-relaxed">
            These are services you are allowed to shop for. If you select your own providers, there are no legal tolerance limits, but you can save thousands of dollars by getting quotes from competing title companies.
          </p>

          <div class="space-y-4">
            <!-- Lender Title Policy -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-border-subtle pb-3">
              <div class="space-y-0.5">
                <label for="title-lender-input" class="text-xs font-bold text-text-main block">Lender's Title Insurance Policy</label>
                <span class="text-3xs text-text-muted block">State Average Title Cost: <strong class="text-text-main font-tabular" id="title-lender-benchmark">$900</strong></span>
              </div>
              <div class="flex items-center gap-3">
                <div class="relative">
                  <span class="absolute left-2.5 top-1.5 text-xs text-text-muted">$</span>
                  <input type="number" id="title-lender-input" value="1350" class="fee-input h-8 w-28 rounded border border-border-input bg-bg-input pl-5 pr-2 text-xs font-tabular text-text-main focus:outline-none" />
                </div>
                <span class="audit-badge px-2 py-0.5 rounded text-4xs font-bold hidden"></span>
              </div>
            </div>

            <!-- Settlement / Escrow Agent Fee -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
              <div class="space-y-0.5">
                <label for="escrow-input" class="text-xs font-bold text-text-main block">Settlement / Closing Escrow Fee</label>
                <span class="text-3xs text-text-muted block">State Average Escrow Cost: <strong class="text-text-main font-tabular" id="escrow-benchmark">$600</strong></span>
              </div>
              <div class="flex items-center gap-3">
                <div class="relative">
                  <span class="absolute left-2.5 top-1.5 text-xs text-text-muted">$</span>
                  <input type="number" id="escrow-input" value="950" class="fee-input h-8 w-28 rounded border border-border-input bg-bg-input pl-5 pr-2 text-xs font-tabular text-text-main focus:outline-none" />
                </div>
                <span class="audit-badge px-2 py-0.5 rounded text-4xs font-bold hidden"></span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- RIGHT: Auditor Scorecard & Script (5 Cols) -->
      <div class="lg:col-span-5 space-y-6 lg:sticky lg:top-20">
        
        <!-- Scorecard Card -->
        <div class="rounded-xl border border-border-subtle bg-bg-card p-5 space-y-6 shadow-md">
          <h2 class="font-display text-sm font-semibold text-text-main border-b border-border-subtle pb-2">Junk Fee Scorecard</h2>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-bg-main p-3.5 rounded-lg border border-border-subtle">
              <span class="text-4xs text-text-muted font-bold uppercase tracking-wider block">Audited Junk Fees</span>
              <span class="text-xl font-extrabold text-text-main font-tabular block" id="scorecard-total-audited">$0</span>
            </div>
            <div class="bg-bg-main p-3.5 rounded-lg border border-border-subtle" id="savings-card">
              <span class="text-4xs text-text-muted font-bold uppercase tracking-wider block">Potential Savings</span>
              <span class="text-xl font-extrabold text-emerald-500 font-tabular block" id="scorecard-potential-savings">$0</span>
            </div>
          </div>

          <div class="space-y-3">
            <div class="flex justify-between text-xs font-semibold">
              <span class="text-text-muted">CFPB Regulatory Risk Status:</span>
              <span id="regulatory-badge" class="px-2 py-0.5 rounded text-4xs font-extrabold"></span>
            </div>
            <div id="risk-description" class="text-3xs text-text-muted leading-relaxed bg-bg-main p-3 rounded-lg border border-border-subtle">
              Reviewing your Loan Estimate input metrics...
            </div>
          </div>

          <!-- High-Ticket Affiliate CTA -->
          <div class="border-t border-border-subtle pt-4 space-y-3">
            <div class="text-3xs text-text-muted font-semibold leading-relaxed">
              * Lender rates or closing costs too high? Compare clean quotes in 2 minutes without impacting credit.
            </div>
            <a 
              href="https://www.credible.com/mortgage" 
              target="_blank" 
              rel="noopener noreferrer sponsored" 
              class="w-full inline-flex h-9 items-center justify-center rounded-lg bg-blue-500 hover:bg-blue-600 text-white font-bold text-xs shadow-sm hover:shadow transition-all text-center"
            >
              Get Competing Mortgage Quotes (Credible)
            </a>
          </div>
        </div>

        <!-- Script Generator Card -->
        <div class="rounded-xl border border-border-subtle bg-bg-card p-5 space-y-4 shadow-sm">
          <h2 class="font-display text-sm font-semibold text-text-main flex items-center justify-between border-b border-border-subtle pb-2">
            <span>Email Negotiation Script</span>
            <button 
              id="copy-script-btn" 
              class="text-4xs font-bold text-brand-accent hover:text-brand-accent-hover focus:outline-none transition-colors border border-brand-accent/20 px-2 py-0.5 rounded bg-brand-accent/5 hover:bg-brand-accent/10 cursor-pointer"
            >
              Copy Script
            </button>
          </h2>

          <p class="text-3xs text-text-muted leading-relaxed">
            Copy and send this email to your Loan Officer. Lenders have the authority to waive origination fees to secure your business, especially if you show competing offers.
          </p>

          <div class="bg-bg-input rounded-lg border border-border-subtle p-3 font-mono text-4xs text-text-main whitespace-pre-wrap leading-relaxed max-h-72 overflow-y-auto cursor-text select-all" id="script-container">
            Loading script templates...
          </div>
        </div>

      </div>

    </div>

    <!-- Educational Guide Content (For SEO Defensibility) -->
    <div class="border-t border-border-subtle pt-10 space-y-6">
      <h2 class="font-display text-lg font-bold text-text-main sm:text-xl">
        Consumer Guide: How to Negotiate Closing Fees and Identify Inflated Charges
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-xs sm:text-sm text-text-muted leading-relaxed">
        <div class="space-y-4">
          <h3 class="font-display font-semibold text-text-main">1. Origination Charges (Section A)</h3>
          <p>
            This section represents what the lender charges to package and process your mortgage. Underwriting and Processing fees are administrative costs that cover back-end logistics. However, many lenders double-charge by assessing separate charges for both. If a lender charges an Application fee, Underwriting fee, and Processing fee, ask them to waive the Application fee and combine or reduce the processing costs.
          </p>
          <h3 class="font-display font-semibold text-text-main">2. Services You Can Shop For (Section C)</h3>
          <p>
            Lender Title Policy and Escrow settlement services represent a significant percentage of your upfront cash closing requirements. Lenders provide an official list of title providers, but you can choose any state-licensed provider. Compare the fees on your LE with local independent title firms. You could save $500–$1,500 simply by switching providers.
          </p>
        </div>
        <div class="space-y-4">
          <h3 class="font-display font-semibold text-text-main">3. Understanding Legal Tolerance Limits</h3>
          <p>
            The CFPB mandates strict legal boundaries for fee increases between the Loan Estimate (LE) and the Closing Disclosure (CD):
          </p>
          <ul class="list-disc list-inside pl-2 space-y-1">
            <li><strong>0% Tolerance:</strong> Origination charges and transfer taxes. These cannot increase by even $1 unless you request a structural change to the mortgage parameters.</li>
            <li><strong>10% Tolerance:</strong> Third-party services selected from the lender's recommended provider list. The cumulative total of these fees cannot rise by more than 10%.</li>
            <li><strong>No Tolerance:</strong> Prepaids, property taxes, homeowner's insurance, and third-party services you shopped for independently.</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- FAQ Accordion -->
    <div class="border-t border-border-subtle pt-10 space-y-6">
      <h2 class="font-display text-lg font-bold text-text-main sm:text-xl">Frequently Asked Questions</h2>
      <dl class="space-y-6 max-w-4xl">
        {faqs.map(faq => (
          <div class="space-y-2">
            <dt class="font-display text-sm font-semibold text-text-main">{faq.question}</dt>
            <dd class="text-xs sm:text-sm text-text-muted leading-relaxed">{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { auditFees, type FeeInput, stateBenchmarks } from '../utils/lenderFeeAuditor';

  const nationalBenchmarks = {
    underwriting: 950,
    processing: 750,
    application: 0,
    points: 0,
    appraisal: 550,
    credit: 45
  };

  // DOM Elements
  const stateSelect = document.getElementById('state-select') as HTMLSelectElement;
  const loanAmountInput = document.getElementById('loan-amount-input') as HTMLInputElement;
  const underwritingInput = document.getElementById('underwriting-input') as HTMLInputElement;
  const processingInput = document.getElementById('processing-input') as HTMLInputElement;
  const applicationInput = document.getElementById('application-input') as HTMLInputElement;
  const pointsInput = document.getElementById('points-input') as HTMLInputElement;
  const appraisalInput = document.getElementById('appraisal-input') as HTMLInputElement;
  const creditInput = document.getElementById('credit-input') as HTMLInputElement;
  const titleLenderInput = document.getElementById('title-lender-input') as HTMLInputElement;
  const escrowInput = document.getElementById('escrow-input') as HTMLInputElement;

  const totalAuditedEl = document.getElementById('scorecard-total-audited');
  const potentialSavingsEl = document.getElementById('scorecard-potential-savings');
  const savingsCard = document.getElementById('savings-card');
  const regulatoryBadge = document.getElementById('regulatory-badge');
  const riskDescription = document.getElementById('risk-description');
  const scriptContainer = document.getElementById('script-container');
  const copyScriptBtn = document.getElementById('copy-script-btn');

  const benchmarkTitleVal = document.getElementById('title-lender-benchmark');
  const benchmarkEscrowVal = document.getElementById('escrow-benchmark');

  function calculateAudit() {
    const state = stateSelect.value;
    
    // Update displayed benchmarks in form label
    const stateData = stateBenchmarks[state] || stateBenchmarks['OTHER'];
    if (benchmarkTitleVal) benchmarkTitleVal.textContent = `$${stateData.title}`;
    if (benchmarkEscrowVal) benchmarkEscrowVal.textContent = `$${stateData.escrow}`;

    // Get current user inputs
    const inputs: FeeInput = {
      underwriting: parseFloat(underwritingInput.value) || 0,
      processing: parseFloat(processingInput.value) || 0,
      application: parseFloat(applicationInput.value) || 0,
      points: parseFloat(pointsInput.value) || 0,
      appraisal: parseFloat(appraisalInput.value) || 0,
      credit: parseFloat(creditInput.value) || 0,
      titleLender: parseFloat(titleLenderInput.value) || 0,
      escrow: parseFloat(escrowInput.value) || 0
    };

    const auditResult = auditFees(state, inputs);

    // Update Scorecard Values
    if (totalAuditedEl) totalAuditedEl.textContent = `$${Math.round(auditResult.totalJunkFees).toLocaleString()}`;
    if (potentialSavingsEl) potentialSavingsEl.textContent = `$${Math.round(auditResult.totalPotentialSavings).toLocaleString()}`;

    if (savingsCard) {
      if (auditResult.totalPotentialSavings > 0) {
        savingsCard.className = "bg-danger/5 p-3.5 rounded-lg border border-danger/30 transition-all";
        if (potentialSavingsEl) potentialSavingsEl.className = "text-xl font-extrabold text-danger font-tabular block animate-pulse";
      } else {
        savingsCard.className = "bg-success/5 p-3.5 rounded-lg border border-success/30 transition-all";
        if (potentialSavingsEl) potentialSavingsEl.className = "text-xl font-extrabold text-success font-tabular block";
      }
    }

    // Update badges
    const items = [
      { el: underwritingInput, label: 'Underwriting' },
      { el: processingInput, label: 'Processing' },
      { el: applicationInput, label: 'Application' },
      { el: appraisalInput, label: 'Appraisal' },
      { el: creditInput, label: 'Credit Report' },
      { el: titleLenderInput, label: 'Lender Title Policy' },
      { el: escrowInput, label: 'Settlement Escrow' }
    ];

    items.forEach(item => {
      const badge = item.el.parentElement.nextElementSibling as HTMLSpanElement;
      if (badge) {
        const flagged = auditResult.flaggedItems.find(f => f.label === item.label);
        if (flagged) {
          badge.textContent = `+$${Math.round(flagged.overcharge)} Over`;
          badge.className = "audit-badge px-2 py-0.5 rounded text-4xs font-bold bg-danger/10 text-danger border border-danger/20 block";
        } else {
          badge.textContent = "Fair Rate";
          badge.className = "audit-badge px-2 py-0.5 rounded text-4xs font-bold bg-success/10 text-success border border-success/20 block";
        }
      }
    });

    // Regulatory Status Update
    if (regulatoryBadge && riskDescription) {
      regulatoryBadge.textContent = auditResult.regulatoryBadge;
      if (auditResult.regulatoryBadge === "HIGH OVERCHARGES") {
        regulatoryBadge.className = "px-2 py-0.5 rounded text-4xs font-extrabold bg-danger text-white border border-danger";
      } else if (auditResult.regulatoryBadge === "MODERATE OVERCHARGES") {
        regulatoryBadge.className = "px-2 py-0.5 rounded text-4xs font-extrabold bg-warning text-white border border-warning";
      } else {
        regulatoryBadge.className = "px-2 py-0.5 rounded text-4xs font-extrabold bg-success text-white border border-success";
      }
      riskDescription.innerHTML = auditResult.riskDescription;
    }

    // Update script container
    if (scriptContainer) {
      scriptContainer.textContent = auditResult.emailScript;
    }
  }

  // Bind change listeners to all elements
  stateSelect.addEventListener('change', calculateAudit);
  loanAmountInput.addEventListener('input', calculateAudit);
  
  const inputsList = [
    underwritingInput, processingInput, applicationInput, pointsInput,
    appraisalInput, creditInput, titleLenderInput, escrowInput
  ];
  
  inputsList.forEach(input => {
    if (input) {
      input.addEventListener('input', calculateAudit);
    }
  });

  // Copy Script Action
  if (copyScriptBtn && scriptContainer) {
    copyScriptBtn.addEventListener('click', () => {
      const text = scriptContainer.textContent || "";
      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyScriptBtn.textContent;
        copyScriptBtn.textContent = "Copied!";
        copyScriptBtn.classList.replace('text-brand-accent', 'text-success');
        setTimeout(() => {
          copyScriptBtn.textContent = originalText;
          copyScriptBtn.classList.replace('text-success', 'text-brand-accent');
        }, 1500);
      });
    });
  }

  // Run initial calculation
  calculateAudit();
</script>
