---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import { guidesDatabase } from '../../data/guides';

export async function getStaticPaths() {
  return [
    { params: { slug: "first-time-home-buyer-guide" }, props: { guideKey: "first-time" } },
    { params: { slug: "pmi-removal-guide" }, props: { guideKey: "pmi-removal" } },
    { params: { slug: "fha-vs-conventional-loans" }, props: { guideKey: "fha-vs-conv" } },
    { params: { slug: "mortgage-closing-costs-explained" }, props: { guideKey: "closing-costs" } },
    { params: { slug: "average-mortgage-rates-by-state" }, props: { guideKey: "state-rates" } },
    { params: { slug: "mortgage-rates-guide" }, props: { guideKey: "mortgage-rates" } },
    { params: { slug: "conforming-loans-guide" }, props: { guideKey: "conforming-loans" } },
    { params: { slug: "jumbo-loans-guide" }, props: { guideKey: "jumbo-loans" } },
    { params: { slug: "loan-amortization-guide" }, props: { guideKey: "loan-amortization" } },
    { params: { slug: "mortgage-points-guide" }, props: { guideKey: "mortgage-points" } },
    { params: { slug: "property-taxes-escrow-guide" }, props: { guideKey: "property-taxes-escrow" } },
    { params: { slug: "dti-ratio-explained-guide" }, props: { guideKey: "dti-ratio-explained" } },
    { params: { slug: "biweekly-payments-guide" }, props: { guideKey: "biweekly-payments" } },
    { params: { slug: "lump-sum-prepayment-guide" }, props: { guideKey: "lump-sum-prepayment" } },
    { params: { slug: "rate-lock-agreements-guide" }, props: { guideKey: "rate-lock-agreements" } },
    { params: { slug: "equity-and-refinance-guide" }, props: { guideKey: "equity-and-refinance" } },
    { params: { slug: "refinance-closing-costs-guide" }, props: { guideKey: "refinance-closing-costs" } },
    { params: { slug: "hoa-fees-affordability-guide" }, props: { guideKey: "hoa-fees-affordability" } },
    { params: { slug: "homeowners-insurance-guide" }, props: { guideKey: "homeowners-insurance" } },
    { params: { slug: "credit-score-mortgage-guide" }, props: { guideKey: "credit-score-mortgage" } }
  ];
}

interface Props {
  guideKey: string;
}

const { guideKey } = Astro.props;
const { slug } = Astro.params;

const guide = guidesDatabase[guideKey];

if (!guide) {
  return Astro.redirect('/404');
}

// Calculate approximate word count
const totalWords = guide.sections.reduce((acc, curr) => acc + curr.heading.split(' ').length + curr.content.split(' ').length, 0);

// Author Metadata lookup
const authorNames = {
  sarah: "Sarah Jenkins, CFP®",
  marcus: "Marcus Vance"
};
const authorName = authorNames[guide.authorKey];

// Construct TechArticle JSON-LD Schema
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": guide.title,
  "description": guide.description,
  "image": "https://mortgagesintel.com/assets/og-guide.png",
  "author": {
    "@type": "Person",
    "name": authorName,
    "jobTitle": guide.authorKey === 'sarah' ? "Chief Underwriting Analyst" : "Senior Credit Advisor"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Mortgage Intelligence Platform",
    "logo": {
      "@type": "ImageObject",
      "url": "https://mortgagesintel.com/favicon.svg"
    }
  },
  "datePublished": "2026-01-15T08:00:00+08:00",
  "dateModified": "2026-06-18T08:00:00+08:00",
  "mainEntityOfPage": `https://mortgagesintel.com/guides/${slug}`,
  "wordCount": totalWords
});

// Related guides (same category or alternative guides)
const allGuidesList = Object.entries(guidesDatabase).map(([key, value]) => ({
  slug: key === "first-time" ? "first-time-home-buyer-guide" :
        key === "pmi-removal" ? "pmi-removal-guide" :
        key === "fha-vs-conv" ? "fha-vs-conventional-loans" :
        key === "closing-costs" ? "mortgage-closing-costs-explained" :
        key === "state-rates" ? "average-mortgage-rates-by-state" :
        key === "mortgage-rates" ? "mortgage-rates-guide" :
        key === "conforming-loans" ? "conforming-loans-guide" :
        key === "jumbo-loans" ? "jumbo-loans-guide" :
        key === "loan-amortization" ? "loan-amortization-guide" :
        key === "mortgage-points" ? "mortgage-points-guide" :
        key === "property-taxes-escrow" ? "property-taxes-escrow-guide" :
        key === "dti-ratio-explained" ? "dti-ratio-explained-guide" :
        key === "biweekly-payments" ? "biweekly-payments-guide" :
        key === "lump-sum-prepayment" ? "lump-sum-prepayment-guide" :
        key === "rate-lock-agreements" ? "rate-lock-agreements-guide" :
        key === "equity-and-refinance" ? "equity-and-refinance-guide" :
        key === "refinance-closing-costs" ? "refinance-closing-costs-guide" :
        key === "hoa-fees-affordability" ? "hoa-fees-affordability-guide" :
        key === "homeowners-insurance" ? "homeowners-insurance-guide" :
        key === "credit-score-mortgage" ? "credit-score-mortgage-guide" : "",
  title: value.title,
  category: value.category
})).filter(g => g.slug !== slug);

const relatedGuides = allGuidesList
  .filter(g => g.category === guide.category)
  .slice(0, 3);

// Fallback to random if not enough in same category
if (relatedGuides.length < 3) {
  const fillers = allGuidesList.filter(g => !relatedGuides.find(rg => rg.slug === g.slug));
  relatedGuides.push(...fillers.slice(0, 3 - relatedGuides.length));
}
---

<Layout 
  title={`${guide.title} - Mortgage Intelligence Guides`}
  description={guide.description}
  canonicalUrl={`/guides/${Astro.params.slug}`}
  schemaMarkup={articleSchema}
>
  <Header activeSlug="" />

  <main class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8 space-y-10 flex-grow">
    <!-- Breadcrumb -->
    <nav class="text-xs text-text-muted flex items-center gap-2">
      <a href="/" class="hover:text-text-main transition-colors">Home</a>
      <span>/</span>
      <span class="text-text-muted">{guide.category}</span>
      <span>/</span>
      <span class="text-text-muted">{guide.title}</span>
    </nav>

    <!-- Guide Header -->
    <div class="space-y-4 border-b border-border-subtle pb-8">
      <div class="inline-flex items-center rounded-full bg-blue-500/10 px-2.5 py-0.5 text-2xs font-medium text-blue-400 border border-blue-500/20">
        {guide.category}
      </div>
      <h1 class="font-display text-3xl font-bold text-text-main sm:text-4xl tracking-tight leading-tight">
        {guide.title}
      </h1>
      
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-2xs text-text-muted pt-1">
        <span>By <strong>{authorName}</strong></span>
        <span>&bull;</span>
        <span>Last Updated: {guide.lastUpdated}</span>
        <span>&bull;</span>
        <span>Reading Time: {Math.ceil(totalWords / 200)} min ({totalWords} words)</span>
      </div>

      <p class="text-sm text-text-muted leading-relaxed max-w-3xl pt-2">
        {guide.description}
      </p>
    </div>

    <!-- Key Takeaways Panel -->
    <div class="rounded-xl border border-brand-accent/20 bg-brand-accent/5 p-6 space-y-3">
      <h3 class="font-display text-xs sm:text-sm font-bold text-text-main flex items-center gap-2">
        <svg class="h-4 w-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>Key Takeaways &amp; Highlights</span>
      </h3>
      <ul class="list-disc pl-5 space-y-2 text-2xs sm:text-xs text-text-muted leading-relaxed">
        {guide.keyTakeaways.map(takeaway => (
          <li>{takeaway}</li>
        ))}
      </ul>
    </div>

    <!-- Guide Content -->
    <article class="space-y-10 text-text-main leading-relaxed text-sm">
      {guide.sections.map(section => (
        <div class="space-y-4">
          <h2 class="font-display text-base sm:text-lg font-bold text-text-main tracking-tight pt-2 border-b border-border-subtle/30 pb-1">
            {section.heading}
          </h2>
          {section.content.split('\n\n').map(paragraph => (
            <p class="text-text-muted leading-relaxed">
              {paragraph}
            </p>
          ))}
        </div>
      ))}
    </article>

    <!-- Author Profile Bio (EEAT Compliance) -->
    <div class="pt-8 border-t border-border-subtle/50">
      <AuthorBio authorKey={guide.authorKey} />
    </div>

    <!-- Internal Link CTA Card -->
    <div class="rounded-xl border border-border-subtle bg-bg-card p-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div class="space-y-1">
        <h3 class="font-display text-sm font-semibold text-text-main">Apply These Insights</h3>
        <p class="text-xs text-text-muted">Run your specific numbers using our specialized decision tools.</p>
      </div>
      <a 
        href={guide.ctaHref} 
        class="inline-flex h-9 items-center justify-center rounded-md bg-brand-primary px-5 text-xs font-semibold text-bg-card hover:opacity-90 active:scale-[0.98] transition-all whitespace-nowrap border border-border-subtle"
      >
        {guide.ctaText}
      </a>
    </div>

    <!-- Related Articles -->
    <div class="space-y-4 pt-8 border-t border-border-subtle/50">
      <h3 class="font-display text-sm font-bold text-text-main">Related Financing Guides</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {relatedGuides.map(rg => (
          <a href={`/guides/${rg.slug}`} class="group p-4 bg-bg-card border border-border-subtle hover:border-border-focus rounded-lg transition-colors flex flex-col justify-between h-full">
            <div class="space-y-2">
              <span class="text-4xs text-brand-accent uppercase tracking-wider font-semibold">{rg.category}</span>
              <h4 class="font-display text-xs font-bold text-text-main group-hover:text-brand-accent transition-colors line-clamp-2 leading-tight">
                {rg.title}
              </h4>
            </div>
            <span class="inline-flex items-center gap-1 text-4xs font-bold text-text-muted group-hover:text-brand-accent pt-3 transition-colors">
              <span>Read Guide</span>
              <svg class="h-2.5 w-2.5 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- Editorial Disclaimer -->
    <div class="border-t border-border-subtle pt-8 text-3xs text-text-muted leading-relaxed">
      <strong>Editorial Policy:</strong> Mortgage Intelligence is committed to objective financial reporting. Our content is thoroughly researched by our technical underwriting analysts. Content is provided for educational purposes and should not be treated as professional financial, legal, or investment counsel.
    </div>
  </main>

  <Footer />
</Layout>
