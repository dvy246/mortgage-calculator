---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const popularLinks = [
  { name: 'House Affordability Calculator', href: '/house-affordability-calculator', desc: 'Determine your max home buying budget.' },
  { name: 'Mortgage Payoff Calculator', href: '/mortgage-payoff-calculator', desc: 'Analyze the impact of terms & APR movements.' },
  { name: 'Extra Payment Calculator', href: '/extra-payment-calculator', desc: 'Model prepayments and interest savings.' },
  { name: 'Refinance Calculator', href: '/refinance-calculator', desc: 'Identify your break-even closing costs.' }
];
---

<Layout title="Page Not Found (404) - Mortgage Intelligence" description="The page you are looking for does not exist. Explore our range of mortgage calculators and scenario planning tools.">
  <Header activeSlug="404" />

  <main class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 flex flex-col justify-center items-center space-y-10 flex-grow">
    <!-- Visual 404 Accent Card -->
    <div class="text-center max-w-md mx-auto space-y-6">
      <div class="inline-flex h-20 w-20 items-center justify-center rounded-2xl bg-bg-card border border-border-subtle shadow-md shadow-brand-accent/5">
        <svg class="h-10 w-10 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <div class="space-y-2">
        <span class="text-3xs font-bold uppercase tracking-widest text-brand-accent">Error Code: 404</span>
        <h1 class="font-display text-4xl font-extrabold tracking-tight text-text-main sm:text-5xl">
          Page Not Found
        </h1>
        <p class="text-sm text-text-muted leading-relaxed">
          The link you followed may be broken, or the page has been moved. Use the quick links below to jump back into our planning engines.
        </p>
      </div>

      <div class="pt-2 flex flex-wrap justify-center gap-4">
        <a 
          href="/" 
          class="inline-flex items-center justify-center rounded-md bg-brand-accent px-4 py-2 text-xs font-semibold text-white hover:bg-brand-accent-hover transition-colors shadow-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
        >
          Return Home
        </a>
        <a 
          href="/house-affordability-calculator" 
          class="inline-flex items-center justify-center rounded-md border border-border-subtle bg-bg-card px-4 py-2 text-xs font-semibold text-text-main hover:bg-bg-card-hover transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
        >
          Affordability Calculator
        </a>
      </div>
    </div>

    <!-- Suggested Tools Grid -->
    <div class="w-full border-t border-border-subtle pt-10 space-y-6">
      <h2 class="font-display text-base font-bold text-text-main tracking-tight text-center">Popular Financial Engines</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {popularLinks.map(link => (
          <a 
            href={link.href}
            class="group p-4 rounded-lg border border-border-subtle bg-bg-card hover:border-border-focus hover:bg-bg-card-hover transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
          >
            <h3 class="font-display text-xs font-bold text-text-main group-hover:text-brand-accent transition-colors">{link.name}</h3>
            <p class="text-2xs text-text-muted mt-1 leading-relaxed">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
