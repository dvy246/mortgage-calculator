---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScenarioComparer from '../components/Calculator/ScenarioComparer.astro';
import MiniMortgageForm from '../components/Calculator/MiniMortgageForm.astro';

const buyingTools = [
  {
    name: "Homebuyer Deal Room & Analyzer",
    href: "/deal-room",
    description: "Our signature moat tool. Input your income and reserves, then add actual homes you're touring to compare DTI limits, payments, and closing cost cash side-by-side.",
    icon: `<svg class="h-6 w-6 text-brand-accent animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
    isFeatured: true
  },
  {
    name: "House Affordability Calculator",
    href: "/house-affordability-calculator",
    description: "Determine your maximum home purchase price based on gross income, recurring monthly debts, and standard Debt-to-Income (DTI) rule brackets.",
    icon: `<svg class="h-6 w-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`
  },
  {
    name: "PMI Calculator",
    href: "/mortgage-calculator-with-pmi",
    description: "Estimate monthly Private Mortgage Insurance costs for down payments below 20%. Calculate exactly when PMI will automatically terminate.",
    icon: `<svg class="h-6 w-6 text-violet-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`
  },
  {
    name: "Assumable Mortgage Savings",
    href: "/assumable-mortgage-calculator",
    description: "Calculate the exact equity cash gap, blended interest rates, and payback timelines when assuming FHA, VA, or USDA mortgages.",
    icon: `<svg class="h-6 w-6 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>`
  },
  {
    name: "Lender Loan Estimate Auditor",
    href: "/lender-fee-auditor",
    description: "Audit closing fees from your lender Loan Estimate. Identify inflated junk charges, compare settlement costs, and generate negotiation drafts.",
    icon: `<svg class="h-6 w-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`
  }
];

const payoffTools = [
  {
    name: "Mortgage Payoff Calculator",
    href: "/mortgage-payoff-calculator",
    description: "Analyze the long-term impact of loan terms and interest rate movements. See full amortization metrics and learn how to reduce your payoff timeline.",
    icon: `<svg class="h-6 w-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`
  },
  {
    name: "Extra Payment Calculator",
    href: "/extra-payment-calculator",
    description: "Model the exact interest savings and years saved by making regular monthly, annual, or one-time extra payments toward your mortgage principal.",
    icon: `<svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>`
  },
  {
    name: "Mortgage Payoff vs Invest",
    href: "/invest-vs-payoff-calculator",
    description: "Compare stock index fund compounding interest vs early debt paydown. Evaluate risk-free return opportunity costs.",
    icon: `<svg class="h-6 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m-9 1v-3a2 2 0 012-2h2a2 2 0 012 2v3m0-6V5a2 2 0 012-2h2a2 2 0 012 2v3m-6 0a2 2 0 002-2h2a2 2 0 002-2" /></svg>`
  },
  {
    name: "Mortgage Recast vs Refi",
    href: "/mortgage-recast-calculator",
    description: "Compare lump-sum recasting payment reductions vs interest savings from full refinancing under current market conditions.",
    icon: `<svg class="h-6 w-6 text-violet-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`
  },
  {
    name: "30-Year Homeownership CapEx Planner",
    href: "/homeownership-capex-planner",
    description: "Interactive 3D model & planning engine to map replacement cycles for your roof, HVAC, and systems. Set monthly sinking fund savings targets.",
    icon: `<svg class="h-6 w-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m0 4h3m-3 0H5m3 10v-4m0 4h3m-3 0H5m14 0V3m0 14h-3m3 0h3m-3-10V3m0 4h-3m3 0h3" /></svg>`,
    badge: "3D Interactive"
  }
];

const advancedTools = [
  {
    name: "Refinance Calculator",
    href: "/refinance-calculator",
    description: "Compare your current mortgage terms against today's rates. Factor in closing costs to identify your break-even month and lifetime net savings.",
    icon: `<svg class="h-6 w-6 text-pink-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>`
  },
  {
    name: "HELOC vs Cash-Out Simulator",
    href: "/heloc-vs-cash-out-refinance-calculator",
    description: "Calculate the weighted blended rate of keeping your primary low-rate mortgage + adding a HELOC, vs a single refinance.",
    icon: `<svg class="h-6 w-6 text-teal-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`
  },
  {
    name: "Co-Buying Mortgage Equity Splitter",
    href: "/co-buying-equity-splitter",
    description: "Calculate dynamic equity shifts over time for unmarried co-buyers with unequal contributions. Configure co-ownership exit and buyout terms.",
    icon: `<svg class="h-6 w-6 text-pink-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`
  },
  {
    name: "Seller Financing & Balloon",
    href: "/seller-financing-calculator",
    description: "Amortize owner-financed contracts, determine remaining principal balances at maturity, and track balloon payoff dates.",
    icon: `<svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`
  }
];

import { guidesDatabase } from '../data/guides';

const guides = Object.entries(guidesDatabase).map(([key, value]) => {
  const slug = key === "first-time" ? "first-time-home-buyer-guide" :
               key === "pmi-removal" ? "pmi-removal-guide" :
               key === "fha-vs-conv" ? "fha-vs-conventional-loans" :
               key === "closing-costs" ? "mortgage-closing-costs-explained" :
               key === "state-rates" ? "average-mortgage-rates-by-state" :
               key === "mortgage-rates" ? "mortgage-rates-guide" :
               key === "conforming-loans" ? "conforming-loans-guide" :
               key === "jumbo-loans" ? "jumbo-loans-guide" :
               key === "loan-amortization" ? "loan-amortization-guide" :
               key === "mortgage-points" ? "mortgage-points-guide" :
               key === "property-taxes-escrow" ? "property-taxes-escrow-guide" :
               key === "dti-ratio-explained" ? "dti-ratio-explained-guide" :
               key === "biweekly-payments" ? "biweekly-payments-guide" :
               key === "lump-sum-prepayment" ? "lump-sum-prepayment-guide" :
               key === "rate-lock-agreements" ? "rate-lock-agreements-guide" :
               key === "equity-and-refinance" ? "equity-and-refinance-guide" :
               key === "refinance-closing-costs" ? "refinance-closing-costs-guide" :
               key === "hoa-fees-affordability" ? "hoa-fees-affordability-guide" :
               key === "homeowners-insurance" ? "homeowners-insurance-guide" :
               key === "credit-score-mortgage" ? "credit-score-mortgage-guide" : "";
               
  return {
    title: value.title,
    slug,
    desc: value.description,
    category: value.category
  };
});

const faqs = [
  {
    q: "What is a mortgage?",
    a: "A mortgage is a specialized debt agreement used to purchase or maintain a home, land, or other real estate. The property itself acts as collateral, securing the loan in case of default."
  },
  {
    q: "How does a mortgage calculator work?",
    a: "A mortgage calculator uses the loan amortization equation to compute your monthly principal and interest payments based on the home price, down payment, interest rate, and term length."
  },
  {
    q: "How much mortgage can I afford?",
    a: "Your affordability depends on your income, existing monthly debts, down payment size, and local property expenses. Underwriters use these metrics to gauge your debt service capacity."
  },
  {
    q: "How much house can I afford based on my income?",
    a: "As a general baseline, you can afford a home valued between 3 to 5 times your gross annual income, depending on your recurring debt liabilities and down payment."
  },
  {
    q: "How much mortgage can I qualify for?",
    a: "Mortgage qualification is determined by lenders evaluating your credit score, debt-to-income (DTI) ratio, employment history, and liquid financial reserves."
  },
  {
    q: "How much can I borrow for a mortgage?",
    a: "Your borrowing limit is capped by your debt-to-income ratio. Typically, conventional guidelines restrict your monthly housing expenses to 28% of your gross monthly income."
  },
  {
    q: "What factors determine how much mortgage I can afford?",
    a: "Key variables include gross household income, monthly debt payments (credit cards, student loans, auto loans), down payment amount, interest rates, property taxes, insurance, and HOA dues."
  },
  {
    q: "How are mortgage payments calculated?",
    a: "Payments are calculated using the amortization formula: M = P * [r(1+r)^n] / [(1+r)^n - 1], where M is monthly payment, P is principal, r is monthly rate, and n is total months."
  },
  {
    q: "What is included in a monthly mortgage payment?",
    a: "A standard monthly payment includes Principal and Interest (P&I), plus Escrow reserves for Property Taxes, Homeowners Insurance, and Private Mortgage Insurance (PMI) if applicable."
  },
  {
    q: "How do mortgage interest rates affect monthly payments?",
    a: "Higher interest rates increase the interest charges added to your balance each month, resulting in higher monthly payments and reducing your overall purchasing power."
  },
  {
    q: "What is an amortization schedule?",
    a: "An amortization schedule is a month-by-month table showing how much of each payment goes toward interest versus principal, and the outstanding balance remaining."
  },
  {
    q: "What is PMI (Private Mortgage Insurance)?",
    a: "PMI is an insurance policy required by lenders when your down payment is under 20% of the purchase price. It protects the lender from default and increases your monthly payment."
  },
  {
    q: "How much down payment do I need for a mortgage?",
    a: "You can put down as little as 3% for conventional loans or 3.5% for FHA loans. VA and USDA loans offer 0% down options. A 20% down payment is required to avoid PMI."
  },
  {
    q: "Should I make extra payments on my mortgage?",
    a: "Yes. Directing extra payments toward your loan principal bypasses frontloaded interest, reduces your outstanding balance faster, and shaves years off your term."
  },
  {
    q: "How can I pay off my mortgage faster?",
    a: "You can pay off your mortgage faster by switching to bi-weekly payments, adding extra principal monthly, making annual lump-sum prepayments, or refinancing to a shorter term."
  },
  {
    q: "How much interest can I save with extra mortgage payments?",
    a: "Depending on your rate and loan size, adding an extra $100 to $200 per month can save you tens of thousands of dollars in cumulative lifetime interest charges."
  },
  {
    q: "How long will it take to pay off my mortgage?",
    a: "A standard term is 15 or 30 years, but making regular extra principal payments can help you pay off a 30-year mortgage in 20 to 25 years."
  },
  {
    q: "Should I refinance my mortgage?",
    a: "Refinancing makes sense if current market interest rates are significantly lower than your current rate, allowing you to reduce your payment or shorten your loan term."
  },
  {
    q: "When does refinancing a mortgage make sense?",
    a: "It makes sense when the monthly savings from a lower interest rate will cover the transaction's closing costs before you plan to sell the home or move (the break-even point)."
  },
  {
    q: "What is the difference between a 15-year and 30-year mortgage?",
    a: "A 15-year mortgage features higher monthly payments but lower interest rates, resulting in half the amortization time and up to 60% savings in total interest costs."
  },
  {
    q: "What is a fixed-rate mortgage?",
    a: "A fixed-rate mortgage locks in your interest rate and monthly principal and interest payment for the entire duration of the loan, protecting you from rate hikes."
  },
  {
    q: "What is an adjustable-rate mortgage (ARM)?",
    a: "An ARM features a fixed rate for an initial period (like 5 or 7 years) and then adjusts periodically based on prevailing market interest rate indices."
  },
  {
    q: "What are the different types of mortgages?",
    a: "Major categories include Conventional loans, Government-backed loans (FHA, VA, USDA), Jumbo loans (for high-value properties), Fixed-rate, and Adjustable-rate mortgages."
  },
  {
    q: "What is the 28/36 debt-to-income (DTI) rule?",
    a: "It is a standard lending guideline: housing costs should not exceed 28% of your gross monthly income, and total debts (housing + other bills) should not exceed 36%."
  },
  {
    q: "What credit score do I need for a mortgage?",
    a: "Conventional loans typically require a minimum score of 620, while FHA loans allow scores down to 580 (or 500 with a 10% down payment). Higher scores yield lower rates."
  },
  {
    q: "How much are closing costs on a mortgage?",
    a: "Closing costs typically average between 2% and 5% of the total loan amount, covering origination charges, title fees, appraisals, government taxes, and escrow prepaids."
  },
  {
    q: "What is the total cost of a mortgage over its lifetime?",
    a: "The total cost represents the initial principal borrowed plus all cumulative interest payments over 15 or 30 years, which can double the original cost of the home."
  },
  {
    q: "How much would the mortgage payment be on a $500,000 house?",
    a: "With a 20% down payment ($400,000 loan) at 6.5% interest, the monthly principal and interest payment is approximately $2,528. Taxes, insurance, and HOA fees are extra."
  },
  {
    q: "What is a reverse mortgage?",
    a: "A reverse mortgage allows homeowners aged 62 and older to borrow against their home equity. The lender pays the borrower, and the loan is repaid when the home is sold."
  },
  {
    q: "What is a commercial mortgage?",
    a: "A commercial mortgage is a loan secured by commercial real estate (office spaces, retail centers, apartment buildings) rather than primary single-family residential properties."
  },
  {
    q: "Mortgage calculator how much can I afford?",
    a: "By entering your gross household income, monthly debt payments, and down payment, an affordability calculator solves for your maximum purchase price within safe DTI margins."
  },
  {
    q: "How does a reverse mortgage work?",
    a: "A reverse mortgage pays you tax-free cash from your home's equity in lump sums, monthly lines, or term payments. Interest accumulates, and the loan is settled when you sell or leave."
  },
  {
    q: "How much does it cost to refinance a mortgage?",
    a: "Refinancing costs match standard closing fees, typically ranging between 2% to 5% of the new loan balance for appraisals, underwriting, title insurance, and recording."
  },
  {
    q: "What is a conforming loan?",
    a: "A conforming loan is a conventional mortgage that meets FHFA guidelines, specifically conforming to credit score limits, debt ratios, and standard loan limits."
  },
  {
    q: "When is a jumbo loan required?",
    a: "A jumbo loan is required when the home purchase price exceeds local conforming loan limits set by the FHFA, necessitating stricter credit and down payment underwriting."
  },
  {
    q: "What are mortgage discount points?",
    a: "Discount points represent prepaid interest purchased by the buyer at closing to permanently lower their ongoing interest rate (usually 1% of the loan amount per point)."
  },
  {
    q: "What is a homestead exemption?",
    a: "A homestead exemption is a legal provision that reduces the taxable value of a primary residence for property tax calculations and caps annual assessment increases."
  },
  {
    q: "How does a bi-weekly payment schedule save money?",
    a: "A bi-weekly schedule results in 26 half-payments annually (equal to 13 full monthly checks), accelerating principal paydown and shaving 4 to 6 years off a standard 30-year term."
  },
  {
    q: "Can I make a lump-sum payment directly to principal?",
    a: "Yes. Homeowners can submit lump-sum prepayments designated as 'Principal Only' to instantly reduce the outstanding loan balance and bypass future interest accruals."
  },
  {
    q: "What is a rate lock agreement?",
    a: "A rate lock guarantees your quoted interest rate for a specific window (usually 30 to 60 days) while your mortgage application is processed, shielding you from rate hikes."
  },
  {
    q: "What is a cash-out refinance?",
    a: "A cash-out refinance replaces your current mortgage with a larger loan, allowing you to withdraw the home equity difference in cash at closing."
  },
  {
    q: "How do monthly HOA dues affect mortgage approval?",
    a: "HOA fees are added directly to your monthly housing expense, raising your front-end DTI ratio and reducing your maximum home purchase budget."
  },
  {
    q: "What is the difference between conforming and jumbo interest rates?",
    a: "Conforming loans are government-backed and highly liquid, usually carrying lower rates, whereas jumbo loans are non-conforming, riskier, and carry independent market pricing spreads."
  }
];

const schemaMarkupObj = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": `<p>${faq.a}</p>`
    }
  }))
};

const schemaMarkup = JSON.stringify(schemaMarkupObj);
---

<Layout title="Mortgage Intelligence Hub - Planning & Analytics" canonicalUrl="/" schemaMarkup={schemaMarkup}>
  <Header activeSlug="home" />

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 space-y-16 flex-grow">
    <!-- Hero Section -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center border-b border-border-subtle pb-12">
      <div class="lg:col-span-7 space-y-6 text-left">
        <div class="inline-flex items-center gap-2 rounded-full border border-border-subtle bg-bg-card px-3 py-1.5 text-xs text-text-muted font-semibold">
          <span class="h-2 w-2 rounded-full bg-brand-accent animate-pulse"></span>
          <span>Advanced Mortgage Planning &amp; Scenario Analytics</span>
        </div>
        <h1 class="font-display text-4xl font-extrabold tracking-tight text-text-main sm:text-5xl lg:text-6.5xl leading-[1.1]">
          Calculate the <span class="text-brand-accent">true cost</span> of buying a home.
        </h1>
        <p class="text-md sm:text-lg text-text-muted leading-relaxed max-w-2xl">
          Model monthly payments, calculate PMI drop milestones, compare refinance break-even dates, and map accelerated payoff timelines on a zero-bloat, privacy-first platform.
        </p>
        <div class="flex flex-wrap gap-4 pt-2">
          <a
            href="/deal-room"
            class="inline-flex h-11 items-center justify-center rounded-lg bg-brand-accent text-white px-6 font-display font-semibold transition-all hover:bg-brand-accent-hover hover:scale-[1.01] active:scale-[0.99] focus:outline-none focus:ring-2 focus:ring-brand-accent"
          >
            Launch Deal Room Analyzer
          </a>
          <a
            href="#guides-section"
            class="inline-flex h-11 items-center justify-center rounded-lg border border-border-subtle bg-bg-card text-text-main px-6 font-display font-semibold transition-all hover:bg-bg-card-hover focus:outline-none focus:ring-2 focus:ring-brand-accent"
          >
            Read Education Guides
          </a>
        </div>
      </div>
      
      <!-- Interactive Quick Mortgage Widget -->
      <div class="lg:col-span-5 rounded-xl border border-border-subtle bg-bg-card p-6 shadow-xs space-y-6 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-accent animate-pulse"></div>
        <div class="space-y-1">
          <h2 class="font-display text-sm font-semibold text-text-main">Quick Cost Estimator</h2>
          <p class="text-3xs text-text-muted">Estimate monthly P&amp;I payments instantly at the fold</p>
        </div>
        
        <div class="space-y-4">
          <div class="space-y-2">
            <div class="flex justify-between text-2xs font-semibold text-text-muted">
              <label for="hero-price-input">Home Purchase Price</label>
              <span id="hero-price-val" class="font-tabular text-text-main font-bold">$400,000</span>
            </div>
            <input 
              id="hero-price-input" 
              type="range" 
              min="100000" 
              max="2000000" 
              step="10000" 
              value="400000" 
              class="w-full h-1.5 cursor-pointer"
            />
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-2">
              <div class="flex justify-between text-2xs font-semibold text-text-muted">
                <label for="hero-down-input">Down Payment (%)</label>
                <span id="hero-down-val" class="font-tabular text-text-main font-bold">20%</span>
              </div>
              <input 
                id="hero-down-input" 
                type="number" 
                min="0" 
                max="99" 
                value="20" 
                class="w-full h-9 rounded border border-border-input bg-bg-input px-3 text-xs text-text-main focus:border-border-focus focus:outline-none"
              />
            </div>
            <div class="space-y-2">
              <div class="flex justify-between text-2xs font-semibold text-text-muted">
                <label for="hero-rate-input">Interest Rate (%)</label>
                <span id="hero-rate-val" class="font-tabular text-text-main font-bold">6.5%</span>
              </div>
              <input 
                id="hero-rate-input" 
                type="number" 
                min="0.1" 
                max="25" 
                step="0.1" 
                value="6.5" 
