  <script>
    // --- Tab Switching Logic ---
    const tabBtnBuying = document.getElementById('tab-btn-buying');
    const tabBtnPayoff = document.getElementById('tab-btn-payoff');
    const tabBtnAdvanced = document.getElementById('tab-btn-advanced');

    const tabPanelBuying = document.getElementById('tab-panel-buying');
    const tabPanelPayoff = document.getElementById('tab-panel-payoff');
    const tabPanelAdvanced = document.getElementById('tab-panel-advanced');

    function setActiveTab(activeBtn: HTMLButtonElement, activePanel: HTMLElement) {
      const allBtns = [tabBtnBuying, tabBtnPayoff, tabBtnAdvanced] as HTMLButtonElement[];
      const allPanels = [tabPanelBuying, tabPanelPayoff, tabPanelAdvanced] as HTMLElement[];

      allBtns.forEach(btn => {
        if (btn) {
          btn.classList.remove('border-brand-accent', 'text-brand-accent');
          btn.classList.add('border-transparent', 'text-text-muted');
        }
      });
      activeBtn.classList.remove('border-transparent', 'text-text-muted');
      activeBtn.classList.add('border-brand-accent', 'text-brand-accent');

      allPanels.forEach(panel => {
        if (panel) panel.classList.add('hidden');
      });
      activePanel.classList.remove('hidden');
    }

    if (tabBtnBuying && tabPanelBuying) {
      tabBtnBuying.addEventListener('click', () => setActiveTab(tabBtnBuying as HTMLButtonElement, tabPanelBuying));
    }
    if (tabBtnPayoff && tabPanelPayoff) {
      tabBtnPayoff.addEventListener('click', () => setActiveTab(tabBtnPayoff as HTMLButtonElement, tabPanelPayoff));
    }
    if (tabBtnAdvanced && tabPanelAdvanced) {
      tabBtnAdvanced.addEventListener('click', () => setActiveTab(tabBtnAdvanced as HTMLButtonElement, tabPanelAdvanced));
    }

    // --- Quick Mortgage Cost Estimator ---
    const heroPriceInput = document.getElementById('hero-price-input') as HTMLInputElement;
    const heroPriceVal = document.getElementById('hero-price-val');
    const heroDownInput = document.getElementById('hero-down-input') as HTMLInputElement;
    const heroRateInput = document.getElementById('hero-rate-input') as HTMLInputElement;
    const heroPayment = document.getElementById('hero-payment');
    const heroCalcCta = document.getElementById('hero-calc-cta') as HTMLAnchorElement;

    function formatUSD(val: number) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
    }

    function calculateQuickEstimator() {
      if (!heroPriceInput || !heroDownInput || !heroRateInput || !heroPayment) return;

      const price = parseFloat(heroPriceInput.value) || 0;
      const downPct = parseFloat(heroDownInput.value) || 0;
      const rate = parseFloat(heroRateInput.value) || 0;

      if (heroPriceVal) {
        heroPriceVal.textContent = formatUSD(price);
      }

      const downAmount = price * (downPct / 100);
      const loanAmount = Math.max(0, price - downAmount);
      const monthlyRate = (rate / 12) / 100;
      const totalMonths = 360; // 30-year fixed baseline

      let monthlyPI = 0;
      if (monthlyRate === 0) {
        monthlyPI = loanAmount / totalMonths;
      } else {
        monthlyPI = loanAmount * (monthlyRate * Math.pow(1 + monthlyRate, totalMonths)) / (Math.pow(1 + monthlyRate, totalMonths) - 1);
      }

      if (isNaN(monthlyPI) || !isFinite(monthlyPI)) {
        monthlyPI = 0;
      }

      heroPayment.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(monthlyPI);

      if (heroCalcCta) {
        heroCalcCta.href = `/mortgage-calculator-with-pmi?homePrice=${price}&downPercent=${downPct}&interestRate=${rate}`;
      }
    }

    if (heroPriceInput) {
      heroPriceInput.addEventListener('input', calculateQuickEstimator);
    }
    if (heroDownInput) {
      heroDownInput.addEventListener('input', calculateQuickEstimator);
    }
    if (heroRateInput) {
      heroRateInput.addEventListener('input', calculateQuickEstimator);
    }

    // Run initial quick estimation
    calculateQuickEstimator();

    // --- FAQ Search Script ---
    const searchInput = document.getElementById('faq-search') as HTMLInputElement;
    const faqItems = document.querySelectorAll('.faq-item');
    const emptyState = document.getElementById('faq-empty-state');

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase().trim();
        let visibleCount = 0;

        faqItems.forEach(item => {
          const detailsEl = item as HTMLDetailsElement;
          const text = detailsEl.innerText.toLowerCase();
          
          if (text.includes(query)) {
            detailsEl.classList.remove('hidden');
            visibleCount++;
          } else {
            detailsEl.classList.add('hidden');
            detailsEl.open = false; // close if hidden
          }
        });

        if (emptyState) {
          if (visibleCount === 0) {
            emptyState.classList.remove('hidden');
          } else {
            emptyState.classList.add('hidden');
          }
        }
      });
    }

    // --- Guides Search and Category Filter Script ---
    const guideSearch = document.getElementById('guide-search') as HTMLInputElement;
    const categoryFilter = document.getElementById('guide-category-filter') as HTMLSelectElement;
    const guideCards = document.querySelectorAll('.guide-card');
    const guidesEmptyState = document.getElementById('guides-empty-state');

    function filterGuides() {
      const query = guideSearch?.value.toLowerCase().trim() || '';
      const category = categoryFilter?.value || 'all';
      let visibleCount = 0;

      guideCards.forEach(card => {
        const el = card as HTMLElement;
        const title = el.getAttribute('data-title') || '';
        const desc = el.getAttribute('data-desc') || '';
        const cat = el.getAttribute('data-category') || '';

        const matchesQuery = title.includes(query) || desc.includes(query);
        const matchesCategory = category === 'all' || cat === category;

        if (matchesQuery && matchesCategory) {
          el.classList.remove('hidden');
          visibleCount++;
        } else {
          el.classList.add('hidden');
        }
      });

      if (guidesEmptyState) {
        if (visibleCount === 0) {
          guidesEmptyState.classList.remove('hidden');
        } else {
          guidesEmptyState.classList.add('hidden');
        }
      }
    }

    if (guideSearch) guideSearch.addEventListener('input', filterGuides);
    if (categoryFilter) categoryFilter.addEventListener('change', filterGuides);
  </script>

  <Footer />
</Layout>
